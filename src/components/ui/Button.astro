---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'md' | 'sm' | 'lg';
  class?: string;
  type?: 'button' | 'submit';
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  type = 'button',
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-xl font-semibold tracking-tight transition-[color,background-color,border-color,box-shadow] duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent';

const variants = {
  primary:
    'bg-accent text-white hover:bg-accent-hover shadow-[0_1px_2px_rgb(0_51_160_/_0.12),0_8px_24px_rgb(0_51_160_/_0.22)] hover:shadow-[0_2px_4px_rgb(0_51_160_/_0.14),0_12px_28px_rgb(0_51_160_/_0.28)]',
  secondary:
    'bg-surface/90 text-ink border border-line-strong/80 backdrop-blur-sm hover:border-accent/40 hover:bg-surface hover:text-accent shadow-sm hover:shadow-card',
  ghost: 'bg-transparent text-ink-muted hover:text-ink hover:bg-ink/5',
};

const sizes = {
  md: 'px-5 py-2.5 text-sm',
  sm: 'px-3.5 py-2 text-sm',
  lg: 'px-7 py-3.5 text-[15px]',
};

const classes = [base, variants[variant], sizes[size], className];
---

{
  href ? (
    <a href={href} class:list={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class:list={classes}>
      <slot />
    </button>
  )
}
