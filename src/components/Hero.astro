---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';
---

<section
  class="relative overflow-hidden bg-[linear-gradient(165deg,#e8eef8_0%,#eef2f8_42%,#f4f6fa_100%)]"
  aria-labelledby="hero-heading"
>
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_90%_60%_at_50%_-12%,rgba(0,51,160,0.14),transparent_55%),radial-gradient(ellipse_45%_40%_at_88%_48%,rgba(0,26,82,0.05),transparent_60%),radial-gradient(ellipse_40%_36%_at_8%_72%,rgba(0,166,81,0.07),transparent_55%)]"
    >
    </div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent">
    </div>
    <div
      class="absolute inset-0 opacity-[0.28] [background-image:linear-gradient(rgba(0,51,160,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(0,51,160,0.04)_1px,transparent_1px)] [background-size:56px_56px] [mask-image:radial-gradient(ellipse_65%_48%_at_50%_12%,black,transparent)]"
    >
    </div>
    <div
      class="absolute inset-x-0 bottom-0 h-32 bg-gradient-to-b from-transparent to-white/50 sm:h-40"
    >
    </div>
  </div>

  <!-- Extra bottom space so the Cohi Insights card can peek without covering copy -->
  <Container class="relative pb-36 pt-14 sm:pb-40 sm:pt-20 lg:pb-44 lg:pt-24">
    <div class="mx-auto max-w-3xl text-center">
      <div class="inline-flex flex-col items-center" data-hero-item>
        <img
          src="https://www.coheus.com/coheus-logo.png"
          alt="Coheus"
          class="h-11 w-auto sm:h-12"
          width="192"
          height="48"
        />
        <p
          class="mt-4 text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-accent sm:text-[0.72rem]"
        >
          Executive intelligence for mortgage lenders
        </p>
        <span
          class="mt-5 h-px w-10 bg-gradient-to-r from-transparent via-accent/50 to-transparent"
          aria-hidden="true"
        >
        </span>
      </div>

      <h1
        id="hero-heading"
        class="mt-7 font-display text-[2.6rem] font-bold leading-[1.1] tracking-[-0.03em] text-balance sm:mt-8 sm:text-[3.5rem] sm:leading-[1.06] lg:text-[4.25rem] lg:leading-[1.04]"
      >
        <span
          class="hero-signal inline-block text-ink opacity-0 motion-reduce:opacity-100"
          data-hero-word
          data-hero-signal
        >Signals.</span>
        <span
          class="text-ink-muted opacity-0 motion-reduce:opacity-100"
          data-hero-word
          data-hero-not-noise
        >
          {' '}Not Noise.
        </span>
      </h1>

      <p
        class="mx-auto mt-6 max-w-xl text-[1.05rem] leading-[1.65] text-ink-muted sm:mt-7 sm:text-lg sm:leading-relaxed"
        data-hero-item
      >
        Cohi turns your lender DNA into a daily briefing&mdash;Critical, Needs Attention, and
        Context&mdash;so mortgage leadership acts before coffee, not after another dashboard hunt.
      </p>

      <div
        class="mt-9 flex flex-wrap items-center justify-center gap-3 sm:mt-10"
        data-hero-item
      >
        <Button href="#how-it-works" class="min-w-[11.5rem] shadow-card">
          <svg class="h-4 w-4 shrink-0" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5" opacity="0.9"
            ></circle>
            <path d="M6.75 5.6v4.8L11 8 6.75 5.6Z" fill="currentColor"></path>
          </svg>
          See Coheus in Action
        </Button>
        <Button href="#demo" variant="secondary" class="min-w-[11.5rem] group">
          Test Drive
          <svg
            class="h-4 w-4 shrink-0 transition-transform duration-200 group-hover:translate-x-0.5"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M3 8h9.5M9.5 4.5 13 8l-3.5 3.5"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
          </svg>
        </Button>
      </div>

      <p
        class="mx-auto mt-7 max-w-md text-[0.8125rem] leading-relaxed tracking-wide text-ink-subtle sm:mt-8"
        data-hero-item
      >
        Fewer dashboards. Clearer signals. Action before coffee.
      </p>
    </div>
  </Container>
</section>

<style>
  .hero-signal.is-gradient {
    background-image: linear-gradient(
      105deg,
      #001a52 0%,
      #0033a0 38%,
      #3366b3 68%,
      #00a651 100%
    );
    background-size: 220% 100%;
    background-position: 0% 50%;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }
</style>
