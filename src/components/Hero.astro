---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';

const signalChips = ['Production', 'Pipeline', 'Operations', 'Profitability', 'Risk'];

const peekMetrics = [
  { label: 'Pipeline', value: 'Watch', tone: 'text-accent' },
  { label: 'Fallout', value: 'Elevated', tone: 'text-warning' },
  { label: 'Cost / Loan', value: 'Rising', tone: 'text-warning' },
  { label: 'Margin', value: 'Pressure', tone: 'text-navy' },
];
---

<section
  class="relative overflow-hidden border-b border-line bg-[linear-gradient(180deg,#f3f8f6_0%,#f7faf9_32%,#ffffff_68%,#f5f8f7_100%)]"
  aria-labelledby="hero-heading"
>
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_85%_55%_at_50%_-8%,rgba(15,95,107,0.11),transparent_58%),radial-gradient(ellipse_40%_35%_at_92%_70%,rgba(19,38,58,0.04),transparent_55%),radial-gradient(ellipse_38%_30%_at_6%_78%,rgba(26,122,136,0.05),transparent_50%)]"
    >
    </div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/25 to-transparent">
    </div>
    <div
      class="absolute inset-0 opacity-[0.35] [background-image:linear-gradient(rgba(15,95,107,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(15,95,107,0.03)_1px,transparent_1px)] [background-size:48px_48px] [mask-image:radial-gradient(ellipse_70%_55%_at_50%_20%,black,transparent)]"
    >
    </div>
  </div>

  <Container class="relative pb-10 pt-12 sm:pb-12 sm:pt-16 lg:pb-14 lg:pt-20">
    <div class="mx-auto max-w-3xl text-center">
      <div
        class="inline-flex flex-col items-center gap-3"
        data-hero-item
      >
        <img
          src="https://www.coheus.com/coheus-logo.png"
          alt="Coheus"
          class="h-10 w-auto sm:h-11"
          width="176"
          height="44"
        />
        <p class="text-sm font-medium tracking-wide text-accent">
          Executive intelligence for mortgage leaders
        </p>
      </div>

      <h1
        id="hero-heading"
        class="mt-5 font-display text-4xl font-semibold tracking-tight text-ink text-balance sm:mt-6 sm:text-5xl lg:text-[3.5rem] lg:leading-[1.1]"
        data-hero-item
      >
        Turn mortgage data into executive clarity.
      </h1>

      <p
        class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-ink-muted sm:text-lg"
        data-hero-item
      >
        Coheus helps mortgage leadership teams see what matters, understand what is changing, and
        act faster from one intelligent workspace.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3" data-hero-item>
        <Button href="#how-it-works">See Coheus in Action</Button>
        <Button href="#demo" variant="secondary">Test Drive</Button>
      </div>

      <p
        class="mx-auto mt-6 max-w-xl text-sm leading-relaxed text-ink-subtle"
        data-hero-item
      >
        Built for leaders who need fewer dashboards, clearer answers, and faster decisions.
      </p>
    </div>

    <!-- Soft product peek → live Executive Center -->
    <div class="relative mx-auto mt-10 max-w-3xl sm:mt-12" data-hero-peek>
      <div
        class="pointer-events-none absolute -top-3 left-1/2 z-10 flex w-full -translate-x-1/2 justify-center gap-1.5 px-4 sm:-top-4 sm:gap-2"
        aria-hidden="true"
      >
        {
          signalChips.map((chip, i) => (
            <span
              class="hero-chip hidden rounded-full border border-accent/15 bg-surface/90 px-2.5 py-1 text-[10px] font-medium text-ink-muted shadow-card backdrop-blur-sm sm:inline-flex"
              style={`--i: ${i}`}
            >
              <span class="mr-1.5 h-1.5 w-1.5 rounded-full bg-accent/60" />
              {chip}
            </span>
          ))
        }
      </div>

      <a
        href="#how-it-works"
        class="group relative block overflow-hidden rounded-2xl border border-line bg-surface shadow-elevated ring-1 ring-accent/5 transition-[transform,box-shadow] duration-300 hover:-translate-y-0.5 hover:shadow-[0_8px_40px_rgb(11_27_43/0.1)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        aria-label="See Coheus Executive Center in action"
      >
        <div
          class="flex items-center justify-between border-b border-line bg-[linear-gradient(180deg,#fbfcfd_0%,#ffffff_100%)] px-4 py-2.5"
        >
          <div class="flex items-center gap-2">
            <span
              class="flex h-6 w-6 items-center justify-center rounded-md bg-navy text-[10px] font-bold text-white"
              aria-hidden="true"
            >
              C
            </span>
            <p class="text-[11px] font-semibold text-ink">Executive Center</p>
          </div>
          <span
            class="inline-flex items-center gap-1.5 rounded-full bg-canvas px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.1em] text-ink-subtle ring-1 ring-line"
          >
            <span class="h-1.5 w-1.5 rounded-full bg-success" aria-hidden="true"></span>
            Live preview
          </span>
        </div>

        <div
          class="bg-[linear-gradient(180deg,#f3f7f6_0%,#f7f9fa_100%)] p-3 sm:p-4"
        >
          <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
            {
              peekMetrics.map((metric) => (
                <div class="rounded-lg border border-line bg-surface px-2.5 py-2 sm:px-3 sm:py-2.5">
                  <p class="text-[10px] font-medium text-ink-subtle">{metric.label}</p>
                  <p class={`mt-0.5 text-xs font-semibold sm:text-sm ${metric.tone}`}>{metric.value}</p>
                </div>
              ))
            }
          </div>

          <div class="mt-2.5 grid gap-2 sm:grid-cols-5 sm:gap-3">
            <div class="rounded-lg border border-warning/25 bg-[#fbf7f0] px-3 py-2.5 sm:col-span-2">
              <p class="text-[10px] font-semibold uppercase tracking-[0.1em] text-warning">
                Needs attention
              </p>
              <p class="mt-1 text-xs font-semibold leading-snug text-ink">
                West Region pull-through is slipping
              </p>
            </div>
            <div
              class="rounded-lg border border-white/10 bg-[linear-gradient(145deg,#13263a_0%,#0f5f6b_100%)] px-3 py-2.5 text-white sm:col-span-3"
            >
              <p class="text-[10px] font-semibold uppercase tracking-[0.1em] text-white/60">
                Cohi Executive Brief
              </p>
              <p class="mt-1 line-clamp-2 text-xs leading-relaxed text-white/85">
                Fallout risk increased in the West Region, driven by longer processing times and lower
                pull-through.
              </p>
            </div>
          </div>
        </div>

        <div
          class="pointer-events-none absolute inset-x-0 bottom-0 h-16 bg-gradient-to-t from-surface/80 to-transparent sm:h-12"
          aria-hidden="true"
        >
        </div>
      </a>

      <a
        href="#how-it-works"
        class="mx-auto mt-5 flex h-9 w-9 items-center justify-center rounded-full border border-line bg-surface text-ink-subtle shadow-card transition-colors hover:border-accent/30 hover:text-accent"
        aria-label="Scroll to see how Coheus works"
        data-hero-item
      >
        <svg class="hero-chevron h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path
            d="M4 6.5 L8 10.5 L12 6.5"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </Container>
</section>

<style>
  .hero-chip {
    animation: hero-chip-float 4.5s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.35s);
  }

  @keyframes hero-chip-float {
    0%,
    100% {
      transform: translateY(0);
      opacity: 0.85;
    }
    50% {
      transform: translateY(-4px);
      opacity: 1;
    }
  }

  .hero-chevron {
    animation: hero-chevron-nudge 2.2s ease-in-out infinite;
  }

  @keyframes hero-chevron-nudge {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(3px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-chip,
    .hero-chevron {
      animation: none !important;
    }
  }
</style>
