---
import Container from './ui/Container.astro';
import Card from './ui/Card.astro';
import SectionHeading from './ui/SectionHeading.astro';

const questions = [
  'Why did cost per loan increase this month?',
  'Which branches are showing early signs of fallout risk?',
  'Where are we seeing productivity gaps?',
  'What is driving margin pressure?',
  'Which teams need attention this week?',
  'What changed across our pipeline?',
];
---

<section
  id="ai-intelligence"
  class="scroll-mt-20 border-b border-line bg-canvas py-20 sm:py-24"
>
  <Container>
    <SectionHeading
      title="Ask better questions. Get executive-ready answers."
      description="Coheus helps leaders move beyond static reporting. With AI-assisted executive intelligence, leadership teams can ask direct business questions, investigate performance issues, and receive clear explanations based on connected lender data."
    />

    <div class="mt-12 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        questions.map((question) => (
          <Card class="h-full !p-5" data-reveal>
            <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-accent">Ask Coheus</p>
            <p class="mt-3 text-sm font-medium leading-snug text-ink sm:text-[15px]">
              “{question}”
            </p>
          </Card>
        ))
      }
    </div>

    <p class="mt-10 text-center text-sm font-medium text-ink-muted" data-reveal>
      AI is most valuable when it understands the business context.
    </p>
  </Container>
</section>
