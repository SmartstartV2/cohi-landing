---
import Container from './ui/Container.astro';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();

const links = [
  { label: 'Platform', href: '#platform' },
  { label: 'Cohi', href: '#ai-intelligence' },
  { label: 'Solutions', href: '#solutions' },
  { label: 'Resources', href: '#resources' },
  { label: 'Company', href: '#company' },
];
---

<footer id="contact" class="scroll-mt-20 bg-surface py-14">
  <Container>
    <div class="flex flex-col gap-10 border-b border-line pb-10 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-sm">
        <a href={base} class="flex items-center" aria-label="Coheus home">
          <img
            src="https://www.coheus.com/coheus-logo.png"
            alt="Coheus"
            class="h-11 w-auto"
            width="176"
            height="44"
          />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-ink-muted">
          Executive intelligence for mortgage leaders.
        </p>
      </div>

      <nav aria-label="Footer" class="flex flex-wrap gap-x-6 gap-y-3">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-sm font-medium text-ink-muted transition-colors hover:text-ink"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Visual-only placeholder anchors for nav items without dedicated sections -->
    <div class="sr-only" aria-hidden="true">
      <span id="resources"></span>
      <span id="company"></span>
    </div>

    <p class="pt-8 text-sm text-ink-subtle">&copy; {year} Coheus. All rights reserved.</p>
  </Container>
</footer>
