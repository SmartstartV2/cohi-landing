---
import Container from './ui/Container.astro';

const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();

const platformLinks = [
  { label: 'Cohi Insights', href: '#platform' },
  { label: 'Ask Cohi', href: '#ai-intelligence' },
  { label: 'How it works', href: '#how-it-works' },
  { label: 'Security', href: '#security' },
];

const solutionLinks = [
  { label: 'Fallout & closings', href: '#problem' },
  { label: 'Pull-through', href: '#problem' },
  { label: 'TopTiering®', href: '#platform' },
  { label: 'Daily briefing', href: '#how-it-works' },
];

const companyLinks = [
  { label: 'About Coheus', href: '#company' },
  { label: 'Resources', href: '#resources' },
  { label: 'Compare', href: '#comparison' },
  { label: 'Test Drive', href: '#demo' },
];

const legalLinks = [
  { label: 'Privacy', href: '#privacy' },
  { label: 'Terms', href: '#terms' },
  { label: 'Security', href: '#security' },
];
---

<footer id="contact" class="relative scroll-mt-20 overflow-hidden bg-navy-deep text-white">
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div
      class="absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_12%_0%,rgba(0,51,160,0.35),transparent_55%),radial-gradient(ellipse_50%_40%_at_92%_100%,rgba(0,166,81,0.16),transparent_50%)]"
    >
    </div>
    <div
      class="absolute inset-0 opacity-[0.18] [background-image:linear-gradient(rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.04)_1px,transparent_1px)] [background-size:64px_64px] [mask-image:radial-gradient(ellipse_80%_70%_at_50%_0%,black,transparent)]"
    >
    </div>
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent-mid/50 to-transparent">
    </div>
  </div>

  <Container class="relative pt-16 pb-10 sm:pt-20 sm:pb-12">
    <div class="grid gap-12 lg:grid-cols-[minmax(0,1.35fr)_minmax(0,1fr)] lg:gap-16">
      <div class="max-w-md" data-reveal>
        <a href={base} class="inline-flex items-center" aria-label="Coheus home">
          <img
            src="https://www.coheus.com/coheus-logo.png"
            alt="Coheus"
            class="h-11 w-auto brightness-0 invert"
            width="176"
            height="44"
          />
        </a>
        <p
          class="mt-5 font-display text-2xl font-semibold leading-snug tracking-tight text-white text-balance sm:text-[1.65rem]"
        >
          Executive intelligence for mortgage lenders.
        </p>
        <p class="mt-4 text-sm leading-relaxed text-white/60 sm:text-[0.9375rem]">
          Cohi turns your lender DNA into clear signals, ranked priorities, and faster leadership
          decisions — Signals. Not Noise.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="#demo"
            class="inline-flex items-center justify-center rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-navy transition-colors hover:bg-canvas focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          >
            Test Drive
          </a>
          <a
            href="mailto:sales@coheus.com?subject=Coheus%20inquiry"
            class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/5 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:border-white/40 hover:bg-white/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
          >
            <svg class="h-4 w-4 shrink-0 opacity-80" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path
                d="M2.5 4.5h11v7h-11v-7Z"
                stroke="currentColor"
                stroke-width="1.3"
                stroke-linejoin="round"
              />
              <path
                d="M2.5 4.5 8 8.5l5.5-4"
                stroke="currentColor"
                stroke-width="1.3"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            sales@coheus.com
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 sm:gap-6" data-reveal>
        <div>
          <h2 class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-accent-mid">
            Platform
          </h2>
          <ul class="mt-4 space-y-3">
            {
              platformLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-white/65 transition-colors hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h2 class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-accent-mid">
            Solutions
          </h2>
          <ul class="mt-4 space-y-3">
            {
              solutionLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-white/65 transition-colors hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="col-span-2 sm:col-span-1">
          <h2 class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-accent-mid">
            Company
          </h2>
          <ul class="mt-4 space-y-3">
            {
              companyLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-white/65 transition-colors hover:text-white"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>

          <div class="mt-6">
            <h2 class="text-[0.7rem] font-semibold uppercase tracking-[0.18em] text-accent-mid">
              Connect
            </h2>
            <div class="mt-3 flex items-center gap-2">
              <a
                href="https://www.linkedin.com/company/teraverde"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-white/15 bg-white/5 text-white/70 transition-colors hover:border-white/35 hover:bg-white/10 hover:text-white"
                aria-label="Teraverde on LinkedIn"
              >
                <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path
                    d="M14.5 14.5h-2.6v-4.1c0-1-.4-1.7-1.3-1.7-.7 0-1.1.5-1.3 1-.1.2-.1.5-.1.8v4H6.6s.1-6.5 0-7.2h2.6v1c.3-.5 1-1.3 2.4-1.3 1.8 0 3.1 1.2 3.1 3.7v3.8ZM3.6 5.2c-.9 0-1.5-.6-1.5-1.3S2.7 2.5 3.6 2.5s1.5.6 1.5 1.4-.6 1.3-1.5 1.3Zm1.3 9.3H2.3V7.3h2.6v7.2Z"
                  />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div
      class="mt-14 grid gap-6 border-t border-white/10 pt-8 sm:grid-cols-[1fr_auto] sm:items-end"
      data-reveal
    >
      <div>
        <p class="font-display text-lg font-medium tracking-tight text-white/90 sm:text-xl">
          Ready for clearer Monday decisions?
        </p>
        <p class="mt-1.5 max-w-lg text-sm leading-relaxed text-white/50">
          Talk with our team about connecting your lender data and standing up an executive
          intelligence loop for leadership.
        </p>
      </div>
      <a
        href="mailto:sales@coheus.com?subject=Coheus%20inquiry"
        class="group inline-flex items-center gap-2 text-sm font-semibold text-accent-mid transition-colors hover:text-white"
      >
        Contact sales
        <svg
          class="h-3.5 w-3.5 transition-transform duration-200 group-hover:translate-x-0.5"
          viewBox="0 0 14 14"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M2.5 7h9M7.5 3.5 11 7l-3.5 3.5"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </a>
    </div>

    <!-- Visual-only placeholder anchors for nav items without dedicated sections -->
    <div class="sr-only" aria-hidden="true">
      <span id="resources"></span>
      <span id="company"></span>
      <span id="privacy"></span>
      <span id="terms"></span>
    </div>

    <div
      class="mt-10 flex flex-col gap-4 border-t border-white/10 pt-6 sm:flex-row sm:items-center sm:justify-between"
    >
      <p class="text-xs text-white/40 sm:text-sm">
        &copy; {year} TVMA, Inc. trading as Teraverde®. Coheus®.
      </p>
      <nav aria-label="Legal" class="flex flex-wrap items-center gap-x-5 gap-y-2">
        {
          legalLinks.map((link) => (
            <a
              href={link.href}
              class="text-xs text-white/40 transition-colors hover:text-white/70 sm:text-sm"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>
  </Container>
</footer>
