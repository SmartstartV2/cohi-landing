---
import Container from './ui/Container.astro';
import SectionHeading from './ui/SectionHeading.astro';

const systems = ['LOS', 'CRM', 'Finance', 'Operations', 'Marketing', 'HR', 'Servicing'];

const fragments = [
  { label: 'Pipeline', value: '—', drift: '-rotate-2 translate-x-1' },
  { label: 'Fallout', value: '?', drift: 'rotate-1 -translate-y-1' },
  { label: 'Cost / loan', value: '···', drift: '-rotate-1 translate-y-0.5' },
  { label: 'Margin', value: '—', drift: 'rotate-2 -translate-x-0.5' },
];

const pains = [
  { title: 'Too many dashboards', body: 'Teams search instead of act.' },
  { title: 'Disconnected data', body: 'Performance lives in silos.' },
  { title: 'Slow visibility', body: 'Leaders see what, not why.' },
  { title: 'Hidden friction', body: 'Cost and fallout compound quietly.' },
];
---

<section id="solutions" class="scroll-mt-20 border-b border-line bg-surface py-20 sm:py-24">
  <Container>
    <SectionHeading
      title="Mortgage leaders do not need more reports. They need clearer signals."
      description="Data already spans LOS, CRM, finance, operations, and servicing. The hard part is knowing which signal matters now."
    />

    <div
      class="problem-stage relative mt-12 overflow-hidden rounded-[1.75rem] border border-line bg-[radial-gradient(120%_80%_at_50%_0%,#e7f3f4_0%,#f6f7f9_42%,#ffffff_100%)] px-5 py-10 sm:mt-14 sm:px-8 sm:py-12 lg:px-12"
      data-problem-stage
    >
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.35]"
        style="background-image: linear-gradient(to right, rgb(11 27 43 / 0.04) 1px, transparent 1px), linear-gradient(to bottom, rgb(11 27 43 / 0.04) 1px, transparent 1px); background-size: 28px 28px;"
        aria-hidden="true"
      >
      </div>

      <p class="relative text-center text-xs font-semibold uppercase tracking-[0.16em] text-ink-subtle">
        Across the mortgage stack
      </p>

      <div
        class="relative mt-5 flex flex-wrap items-center justify-center gap-2 sm:gap-2.5"
        aria-label="Disconnected systems"
      >
        {
          systems.map((system) => (
            <span
              class="problem-chip rounded-lg border border-line-strong/80 bg-surface/90 px-3 py-1.5 text-xs font-medium text-ink-muted shadow-card sm:text-sm"
              data-problem-chip
            >
              {system}
            </span>
          ))
        }
      </div>

      <div class="relative mx-auto mt-8 max-w-3xl" aria-hidden="true">
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4">
          {
            fragments.map((item) => (
              <div
                class:list={[
                  'problem-fragment rounded-xl border border-dashed border-line-strong bg-surface/70 px-3.5 py-3 backdrop-blur-[2px]',
                  item.drift,
                ]}
                data-problem-fragment
              >
                <p class="text-[11px] font-medium uppercase tracking-[0.12em] text-ink-subtle">
                  {item.label}
                </p>
                <p class="mt-1.5 font-display text-xl font-semibold tracking-tight text-ink/35">
                  {item.value}
                </p>
              </div>
            ))
          }
        </div>

        <div class="pointer-events-none absolute inset-x-6 top-1/2 h-px -translate-y-1/2 sm:inset-x-10">
          <div
            class="problem-scan absolute inset-y-0 left-0 w-1/3 bg-gradient-to-r from-transparent via-accent/50 to-transparent"
            data-problem-scan
          >
          </div>
        </div>
      </div>

      <div class="relative mx-auto mt-8 max-w-md text-center" data-problem-focus>
        <div class="mx-auto mb-4 h-10 w-px bg-gradient-to-b from-line-strong to-ink/20" aria-hidden="true"></div>
        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-subtle">Leadership view</p>
        <p class="mt-2 font-display text-2xl font-semibold tracking-tight text-ink sm:text-[1.75rem]">
          No clear signal
        </p>
        <p class="mt-2 text-sm text-ink-muted">
          Priority today:
          <span
            class="problem-priority ml-1 inline-block min-w-[9.5rem] border-b border-dashed border-ink/25 text-left font-medium text-ink/45"
            data-problem-priority
            aria-live="polite"
          >
            —
          </span>
        </p>
      </div>

      <ul class="relative mx-auto mt-10 grid max-w-3xl gap-x-8 gap-y-5 sm:grid-cols-2">
        {
          pains.map((item) => (
            <li class="border-l-2 border-line-strong pl-4" data-problem-pain>
              <p class="text-sm font-semibold tracking-tight text-ink">{item.title}</p>
              <p class="mt-1 text-sm leading-relaxed text-ink-muted">{item.body}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </Container>
</section>
