---
import Container from './ui/Container.astro';
import SectionHeading from './ui/SectionHeading.astro';

const moments = [
  {
    without: 'Weekly ops pack arrives mid-meeting',
    with: 'Daily Brief before the first call',
  },
  {
    without: 'Every metric looks equally urgent',
    with: 'Critical ranked—fallout and late closings first',
  },
  {
    without: 'Leaders debate which dashboard to trust',
    with: 'One shared signal across executive, ops, and production',
  },
  {
    without: 'Drivers discovered after the decision window',
    with: 'Drivers and takeaway in the brief—act before coffee',
  },
];
---

<section id="comparison" class="scroll-mt-20 bg-canvas py-20 sm:py-24">
  <Container>
    <SectionHeading
      eyebrow="Monday morning"
      title="What changes when Cohi is in the loop."
      description="Same lender DNA. Different ritual—ranked urgency instead of another dashboard hunt."
    />

    <div
      class="relative mt-12 overflow-hidden rounded-2xl border border-line bg-surface shadow-card lg:mt-14"
      data-reveal
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_70%_50%_at_50%_0%,rgba(0,51,160,0.05),transparent_55%)]"
        aria-hidden="true"
      >
      </div>

      <div
        class="relative grid border-b border-line sm:grid-cols-2"
      >
        <div class="flex items-center gap-2 border-b border-line px-5 py-3.5 sm:border-b-0 sm:border-r sm:px-6">
          <span
            class="inline-flex items-center rounded-md bg-[#f8efe2] px-2 py-0.5 text-[10px] font-bold uppercase tracking-[0.12em] text-warning ring-1 ring-warning/20"
          >
            Without Cohi
          </span>
          <span class="text-[11px] font-medium text-ink-subtle">Weekly ops pack</span>
        </div>
        <div class="flex items-center gap-2 px-5 py-3.5 sm:px-6">
          <span
            class="inline-flex items-center rounded-md bg-accent-soft px-2 py-0.5 text-[10px] font-bold uppercase tracking-[0.12em] text-accent ring-1 ring-accent/20"
          >
            With Cohi
          </span>
          <span class="text-[11px] font-medium text-ink-subtle">Daily Briefing</span>
        </div>
      </div>

      <ul class="relative m-0 list-none divide-y divide-line p-0">
        {
          moments.map((moment) => (
            <li class="grid sm:grid-cols-2">
              <p class="border-b border-line px-5 py-4 text-sm leading-relaxed text-ink-muted sm:border-b-0 sm:border-r sm:px-6 sm:py-5 sm:text-[15px]">
                {moment.without}
              </p>
              <p class="px-5 py-4 text-sm font-medium leading-relaxed text-ink sm:px-6 sm:py-5 sm:text-[15px]">
                {moment.with}
              </p>
            </li>
          ))
        }
      </ul>

      <div
        class="relative border-t border-line bg-canvas/50 px-5 py-4 sm:px-6"
      >
        <p class="text-sm leading-relaxed text-ink-muted sm:text-[15px]">
          <span class="font-semibold text-ink">Signals. Not Noise.</span>
          {' '}
          Cohi doesn’t replace your warehouse—it ranks what leadership should decide on this morning.
        </p>
      </div>
    </div>
  </Container>
</section>
