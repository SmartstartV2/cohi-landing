---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';

const base = import.meta.env.BASE_URL;

const centerLinks = [
  { label: 'Home', href: '#top' },
  { label: 'Why Cohi', href: '#problem' },
  { label: 'Cohi', href: '#ai-intelligence' },
  { label: 'Platform', href: '#platform' },
  { label: 'HMDA', href: null },
];
---

<header
  class="nav-header sticky top-0 z-50 border-b border-transparent bg-surface/70 backdrop-blur-xl transition-[background-color,border-color,box-shadow] duration-300 data-[scrolled=true]:border-line/70 data-[scrolled=true]:bg-surface/92 data-[scrolled=true]:shadow-[0_1px_0_rgb(11_27_43_/_0.03),0_8px_24px_rgb(11_27_43_/_0.04)]"
  data-nav
  data-scrolled="false"
>
  <div
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/25 to-transparent"
    aria-hidden="true"
  >
  </div>

  <Container class="relative flex h-[4.25rem] items-center justify-between gap-4">
    <a
      href={base}
      class="relative z-10 flex shrink-0 items-center transition-opacity duration-200 hover:opacity-80"
      aria-label="Coheus home"
      data-nav-home
    >
      <img
        src="https://www.coheus.com/coheus-logo.png"
        alt="Coheus"
        class="h-9 w-auto sm:h-10"
        width="160"
        height="40"
      />
    </a>

    <nav
      class="absolute left-1/2 top-1/2 hidden -translate-x-1/2 -translate-y-1/2 items-center gap-1 lg:flex"
      aria-label="Primary"
    >
      {
        centerLinks.map((link) =>
          link.href ? (
            <a
              href={link.href}
              class="nav-link group relative px-3 py-2 text-[0.8125rem] font-medium tracking-[0.01em] text-ink-muted transition-colors duration-200 hover:text-ink"
            >
              {link.label}
              <span
                class="pointer-events-none absolute inset-x-3 -bottom-px h-px origin-center scale-x-0 bg-accent/70 transition-transform duration-300 ease-out group-hover:scale-x-100"
                aria-hidden="true"
              />
            </a>
          ) : (
            <span class="relative px-3 py-2 text-[0.8125rem] font-medium tracking-[0.01em] text-ink-muted">
              {link.label}
            </span>
          ),
        )
      }
    </nav>

    <div class="relative z-10 flex items-center gap-1.5 sm:gap-2">
      <a
        href="#contact"
        class="nav-link group relative hidden px-3 py-2 text-[0.8125rem] font-medium tracking-[0.01em] text-ink-muted transition-colors duration-200 hover:text-ink sm:inline-flex"
      >
        Contact
        <span
          class="pointer-events-none absolute inset-x-3 -bottom-px h-px origin-center scale-x-0 bg-accent/70 transition-transform duration-300 ease-out group-hover:scale-x-100"
          aria-hidden="true"
        >
        </span>
      </a>
      <div class="hidden sm:block">
        <Button href="#demo" size="sm" class="group shadow-sm">
          Test Drive
          <svg
            class="h-3.5 w-3.5 shrink-0 transition-transform duration-200 group-hover:translate-x-0.5"
            viewBox="0 0 16 16"
            fill="none"
            aria-hidden="true"
          >
            <path
              d="M3 8h9.5M9.5 4.5 13 8l-3.5 3.5"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
            </path>
          </svg>
        </Button>
      </div>

      <button
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-line/90 bg-surface/80 text-ink transition-colors duration-200 hover:border-accent/30 hover:text-accent lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-nav"
        data-nav-toggle
        aria-label="Open menu"
      >
        <span class="relative h-4 w-4" aria-hidden="true">
          <span
            class="absolute left-0 top-0.5 block h-[1.5px] w-4 rounded-full bg-current transition-transform duration-300 ease-out"
            data-burger-top
          >
          </span>
          <span
            class="absolute left-0 top-[7px] block h-[1.5px] w-4 rounded-full bg-current transition-opacity duration-200"
            data-burger-mid
          >
          </span>
          <span
            class="absolute left-0 top-[13px] block h-[1.5px] w-4 rounded-full bg-current transition-transform duration-300 ease-out"
            data-burger-bot
          >
          </span>
        </span>
      </button>
    </div>
  </Container>

  <div
    id="mobile-nav"
    class="grid grid-rows-[0fr] overflow-hidden border-t border-transparent bg-surface/95 backdrop-blur-xl transition-[grid-template-rows,border-color] duration-300 ease-out lg:hidden data-[open=true]:grid-rows-[1fr] data-[open=true]:border-line/70"
    data-mobile-nav
    data-open="false"
  >
    <div class="min-h-0 overflow-hidden">
      <Container class="flex flex-col gap-0.5 py-3 pb-4">
        {
          centerLinks.map((link) =>
            link.href ? (
              <a
                href={link.href}
                class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-muted transition-colors duration-200 hover:bg-accent-soft/60 hover:text-ink"
              >
                {link.label}
              </a>
            ) : (
              <span class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-muted">
                {link.label}
              </span>
            ),
          )
        }
        <a
          href="#contact"
          class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-muted transition-colors duration-200 hover:bg-accent-soft/60 hover:text-ink"
        >
          Contact
        </a>
        <div class="mt-2 px-3 pb-1">
          <Button href="#demo" class="group w-full">
            Test Drive
            <svg
              class="h-3.5 w-3.5 shrink-0 transition-transform duration-200 group-hover:translate-x-0.5"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M3 8h9.5M9.5 4.5 13 8l-3.5 3.5"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
              </path>
            </svg>
          </Button>
        </div>
      </Container>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-nav]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-mobile-nav]');
  const burgerTop = document.querySelector<HTMLElement>('[data-burger-top]');
  const burgerMid = document.querySelector<HTMLElement>('[data-burger-mid]');
  const burgerBot = document.querySelector<HTMLElement>('[data-burger-bot]');

  const setScrolled = () => {
    const scrolled = window.scrollY > 8;
    header?.setAttribute('data-scrolled', String(scrolled));
  };

  const setOpen = (open: boolean) => {
    panel?.setAttribute('data-open', String(open));
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');

    if (burgerTop && burgerMid && burgerBot) {
      burgerTop.style.transform = open ? 'translateY(5.5px) rotate(45deg)' : '';
      burgerMid.style.opacity = open ? '0' : '1';
      burgerBot.style.transform = open ? 'translateY(-5.5px) rotate(-45deg)' : '';
    }
  };

  setScrolled();
  window.addEventListener('scroll', setScrolled, { passive: true });

  toggle?.addEventListener('click', () => {
    setOpen(panel?.getAttribute('data-open') !== 'true');
  });

  panel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  const scrollHome = (event: Event) => {
    event.preventDefault();
    setOpen(false);
    window.scrollTo({ top: 0, behavior: 'smooth' });
    if (window.location.hash) {
      history.replaceState(null, '', window.location.pathname + window.location.search);
    }
  };

  document.querySelectorAll<HTMLAnchorElement>('a[href="#top"], [data-nav-home]').forEach((link) => {
    link.addEventListener('click', scrollHome);
  });
</script>
