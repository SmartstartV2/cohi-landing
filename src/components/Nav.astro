---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';

const base = import.meta.env.BASE_URL;

const centerLinks = [
  { label: 'Platform', href: '#platform' },
  { label: 'Cohi', href: '#ai-intelligence' },
  { label: 'Solutions', href: '#solutions' },
  { label: 'Resources', href: '#resources' },
  { label: 'Company', href: '#company' },
];
---

<header
  class="sticky top-0 z-50 border-b border-line/80 bg-surface/85 backdrop-blur-md"
  data-nav
>
  <Container class="flex h-16 items-center justify-between gap-4">
    <a href={base} class="flex items-center" aria-label="Coheus home">
      <img
        src="https://www.coheus.com/coheus-logo.png"
        alt="Coheus"
        class="h-11 w-auto"
        width="176"
        height="44"
      />
    </a>

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Primary">
      {
        centerLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-ink-muted transition-colors hover:text-ink"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-3 sm:flex">
      <a
        href="#contact"
        class="text-sm font-medium text-ink-muted transition-colors hover:text-ink"
      >
        Contact
      </a>
      <Button href="#demo" size="sm">Test Drive</Button>
    </div>

    <button
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-line text-ink lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-nav"
      data-nav-toggle
      aria-label="Open menu"
    >
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" aria-hidden="true">
        <path
          d="M3.5 6.5h13M3.5 10h13M3.5 13.5h13"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"></path>
      </svg>
    </button>
  </Container>

  <div id="mobile-nav" class="hidden border-t border-line bg-surface lg:hidden" data-mobile-nav>
    <Container class="flex flex-col gap-1 py-4">
      {
        centerLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-muted hover:bg-canvas hover:text-ink"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="#contact"
        class="rounded-lg px-3 py-2.5 text-sm font-medium text-ink-muted hover:bg-canvas hover:text-ink"
      >
        Contact
      </a>
      <div class="mt-2 px-3 pb-1">
        <Button href="#demo" class="w-full">Test Drive</Button>
      </div>
    </Container>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const panel = document.querySelector<HTMLElement>('[data-mobile-nav]');

  const setOpen = (open: boolean) => {
    panel?.classList.toggle('hidden', !open);
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  };

  toggle?.addEventListener('click', () => {
    setOpen(panel?.classList.contains('hidden') ?? true);
  });

  panel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });
</script>
