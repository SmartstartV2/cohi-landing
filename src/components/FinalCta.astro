---
import Container from './ui/Container.astro';
import Button from './ui/Button.astro';

const sparks = [
  { left: '7%', top: '18%', size: 3, tone: 'blue', delay: '0s', dur: '11s', path: 'a' },
  { left: '14%', top: '42%', size: 2, tone: 'green', delay: '1.4s', dur: '13s', path: 'b' },
  { left: '9%', top: '68%', size: 2.5, tone: 'blue', delay: '0.6s', dur: '10s', path: 'c' },
  { left: '22%', top: '24%', size: 2, tone: 'mid', delay: '2.1s', dur: '14s', path: 'a' },
  { left: '18%', top: '78%', size: 3, tone: 'green', delay: '3s', dur: '12s', path: 'b' },
  { left: '28%', top: '56%', size: 2, tone: 'blue', delay: '0.9s', dur: '15s', path: 'c' },
  { left: '78%', top: '20%', size: 2.5, tone: 'blue', delay: '1.2s', dur: '11s', path: 'b' },
  { left: '86%', top: '36%', size: 3, tone: 'green', delay: '0.3s', dur: '13s', path: 'a' },
  { left: '92%', top: '58%', size: 2, tone: 'mid', delay: '2.6s', dur: '10s', path: 'c' },
  { left: '84%', top: '74%', size: 2.5, tone: 'blue', delay: '1.8s', dur: '14s', path: 'b' },
  { left: '72%', top: '82%', size: 2, tone: 'green', delay: '0.5s', dur: '12s', path: 'a' },
  { left: '6%', top: '88%', size: 2, tone: 'mid', delay: '3.4s', dur: '16s', path: 'c' },
  { left: '48%', top: '12%', size: 2, tone: 'blue', delay: '2s', dur: '13s', path: 'b' },
  { left: '56%', top: '86%', size: 2.5, tone: 'green', delay: '1.1s', dur: '11s', path: 'a' },
  { left: '38%', top: '16%', size: 2, tone: 'mid', delay: '4s', dur: '15s', path: 'c' },
  { left: '64%', top: '14%', size: 3, tone: 'blue', delay: '2.8s', dur: '12s', path: 'b' },
];
---

<section
  id="demo"
  class="final-cta relative scroll-mt-20 overflow-hidden bg-[linear-gradient(160deg,#e8eef7_0%,#eef2f8_40%,#f5f7fa_100%)] py-20 text-ink sm:py-28"
  aria-labelledby="final-cta-heading"
>
  <div class="final-cta-bg pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <!-- Soft brand atmosphere -->
    <div class="final-cta-wash final-cta-wash--blue"></div>
    <div class="final-cta-wash final-cta-wash--green"></div>

    <!-- Precision lattice -->
    <div class="final-cta-lattice"></div>

    <!-- Rotating orbital rings (uniform scale, never stretched dots) -->
    <div class="final-cta-orbit final-cta-orbit--outer">
      <span class="final-cta-orbit-ring"></span>
    </div>
    <div class="final-cta-orbit final-cta-orbit--mid">
      <span class="final-cta-orbit-ring"></span>
      <span class="final-cta-orbit-bead"></span>
    </div>
    <div class="final-cta-orbit final-cta-orbit--inner">
      <span class="final-cta-orbit-ring"></span>
      <span class="final-cta-orbit-bead final-cta-orbit-bead--alt"></span>
    </div>

    <!-- Drift sparks -->
    {
      sparks.map((spark) => (
        <span
          class:list={[
            'final-cta-spark',
            `final-cta-spark--${spark.tone}`,
            `final-cta-spark--${spark.path}`,
          ]}
          style={`left:${spark.left};top:${spark.top};width:${spark.size}px;height:${spark.size}px;--spark-delay:${spark.delay};--spark-dur:${spark.dur}`}
        />
      ))
    }

    <!-- Horizontal signal traces -->
    <div class="final-cta-trace final-cta-trace--a"></div>
    <div class="final-cta-trace final-cta-trace--b"></div>
    <div class="final-cta-trace final-cta-trace--c"></div>

    <!-- Corner brackets -->
    <span class="final-cta-corner final-cta-corner--tl"></span>
    <span class="final-cta-corner final-cta-corner--tr"></span>
    <span class="final-cta-corner final-cta-corner--bl"></span>
    <span class="final-cta-corner final-cta-corner--br"></span>
  </div>

  <Container class="relative z-10">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <div
        class="final-cta-glass relative rounded-3xl px-6 py-10 sm:px-10 sm:py-12"
      >
        <div
          class="pointer-events-none absolute inset-x-10 top-0 h-px bg-gradient-to-r from-transparent via-white/80 to-transparent"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute inset-0 rounded-3xl bg-[radial-gradient(ellipse_90%_50%_at_50%_-10%,rgba(255,255,255,0.28),transparent_50%)]"
          aria-hidden="true"
        >
        </div>

        <div class="relative">
          <p class="inline-flex items-center gap-2 text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-accent">
            <span class="final-cta-live h-1.5 w-1.5 rounded-full bg-accent" aria-hidden="true"></span>
            Get started
          </p>
          <h2
            id="final-cta-heading"
            class="mt-4 font-display text-3xl font-semibold tracking-tight text-ink text-balance sm:text-4xl lg:text-5xl"
          >
            Turn lender DNA into executive clarity.
          </h2>
          <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-ink-muted sm:text-lg">
            See how Cohi ranks Critical signals, explains fallout and production drivers, and helps
            mortgage leadership act from one morning brief.
          </p>
          <div
            class="mt-10 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center sm:gap-4"
          >
            <Button
              href="mailto:sales@coheus.com?subject=Coheus%20Test%20Drive"
              size="lg"
              class="final-cta-primary min-w-[12.5rem] justify-center"
            >
              Test Drive
              <span class="final-cta-arrow inline-block" aria-hidden="true">→</span>
            </Button>
            <Button
              href="#contact"
              variant="secondary"
              size="lg"
              class="min-w-[12.5rem] justify-center"
            >
              Contact Us
            </Button>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>

<style is:global>
  #demo.final-cta .final-cta-wash {
    position: absolute;
    border-radius: 9999px;
    filter: blur(56px);
    opacity: 0.45;
  }

  #demo.final-cta .final-cta-wash--blue {
    top: -8%;
    left: 50%;
    width: min(52vw, 34rem);
    height: min(36vw, 22rem);
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(0, 51, 160, 0.22) 0%, transparent 70%);
    animation: demo-wash 14s ease-in-out infinite;
  }

  #demo.final-cta .final-cta-wash--green {
    right: 8%;
    bottom: 6%;
    width: 14rem;
    height: 14rem;
    background: radial-gradient(circle, rgba(0, 166, 81, 0.14) 0%, transparent 70%);
    animation: demo-wash-alt 18s ease-in-out infinite;
  }

  #demo.final-cta .final-cta-lattice {
    position: absolute;
    inset: 0;
    opacity: 0.35;
    background-image:
      linear-gradient(rgba(0, 51, 160, 0.06) 0.5px, transparent 0.5px),
      linear-gradient(90deg, rgba(0, 51, 160, 0.06) 0.5px, transparent 0.5px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse 70% 65% at 50% 50%, black 15%, transparent 75%);
    animation: demo-lattice 48s linear infinite;
  }

  #demo.final-cta .final-cta-orbit {
    position: absolute;
    left: 50%;
    top: 50%;
    border-radius: 9999px;
    transform: translate(-50%, -50%);
  }

  #demo.final-cta .final-cta-orbit--outer {
    width: min(92vw, 52rem);
    height: min(92vw, 52rem);
    animation: demo-spin 48s linear infinite;
  }

  #demo.final-cta .final-cta-orbit--mid {
    width: min(72vw, 40rem);
    height: min(72vw, 40rem);
    animation: demo-spin-rev 36s linear infinite;
  }

  #demo.final-cta .final-cta-orbit--inner {
    width: min(48vw, 28rem);
    height: min(48vw, 28rem);
    animation: demo-spin 28s linear infinite;
  }

  #demo.final-cta .final-cta-orbit-ring {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 9999px;
    border: 0.5px solid rgba(0, 51, 160, 0.12);
    border-top-color: rgba(0, 51, 160, 0.28);
    border-right-color: rgba(0, 166, 81, 0.16);
    box-shadow: inset 0 0 0 0.5px rgba(255, 255, 255, 0.2);
  }

  #demo.final-cta .final-cta-orbit-bead {
    position: absolute;
    top: 0;
    left: 50%;
    width: 6px;
    height: 6px;
    margin: -3px 0 0 -3px;
    border-radius: 9999px;
    background: #0033a0;
    box-shadow: 0 0 0 3px rgba(0, 51, 160, 0.12), 0 0 12px rgba(0, 51, 160, 0.25);
  }

  #demo.final-cta .final-cta-orbit-bead--alt {
    background: #00a651;
    box-shadow: 0 0 0 3px rgba(0, 166, 81, 0.14), 0 0 12px rgba(0, 166, 81, 0.2);
    top: auto;
    bottom: 12%;
    left: 8%;
  }

  #demo.final-cta .final-cta-spark {
    position: absolute;
    border-radius: 9999px;
    opacity: 0.55;
    will-change: transform, opacity;
    animation: demo-spark-a var(--spark-dur, 12s) ease-in-out infinite;
    animation-delay: var(--spark-delay, 0s);
  }

  #demo.final-cta .final-cta-spark--blue {
    background: #0033a0;
    box-shadow: 0 0 0 2px rgba(0, 51, 160, 0.1);
  }

  #demo.final-cta .final-cta-spark--green {
    background: #00a651;
    box-shadow: 0 0 0 2px rgba(0, 166, 81, 0.12);
  }

  #demo.final-cta .final-cta-spark--mid {
    background: #3366b3;
    box-shadow: 0 0 0 2px rgba(51, 102, 179, 0.12);
  }

  #demo.final-cta .final-cta-spark--a {
    animation-name: demo-spark-a;
  }

  #demo.final-cta .final-cta-spark--b {
    animation-name: demo-spark-b;
  }

  #demo.final-cta .final-cta-spark--c {
    animation-name: demo-spark-c;
  }

  #demo.final-cta .final-cta-trace {
    position: absolute;
    left: 0;
    height: 0.5px;
    width: 100%;
    overflow: hidden;
  }

  #demo.final-cta .final-cta-trace::after {
    content: '';
    position: absolute;
    top: 0;
    left: -30%;
    width: 30%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(0, 51, 160, 0.35),
      rgba(0, 166, 81, 0.4),
      rgba(0, 51, 160, 0.25),
      transparent
    );
    animation: demo-trace 7s ease-in-out infinite;
  }

  #demo.final-cta .final-cta-trace--a {
    top: 22%;
    opacity: 0.7;
  }

  #demo.final-cta .final-cta-trace--b {
    top: 50%;
    opacity: 0.55;
  }

  #demo.final-cta .final-cta-trace--b::after {
    animation-duration: 9s;
    animation-delay: -2.5s;
  }

  #demo.final-cta .final-cta-trace--c {
    top: 78%;
    opacity: 0.45;
  }

  #demo.final-cta .final-cta-trace--c::after {
    animation-duration: 8s;
    animation-delay: -4s;
  }

  #demo.final-cta .final-cta-corner {
    position: absolute;
    width: 18px;
    height: 18px;
    border-color: rgba(0, 51, 160, 0.35);
    border-style: solid;
    border-width: 0;
    opacity: 0.7;
  }

  #demo.final-cta .final-cta-corner--tl {
    top: 1.25rem;
    left: 1.25rem;
    border-top-width: 0.5px;
    border-left-width: 0.5px;
  }

  #demo.final-cta .final-cta-corner--tr {
    top: 1.25rem;
    right: 1.25rem;
    border-top-width: 0.5px;
    border-right-width: 0.5px;
  }

  #demo.final-cta .final-cta-corner--bl {
    bottom: 1.25rem;
    left: 1.25rem;
    border-bottom-width: 0.5px;
    border-left-width: 0.5px;
  }

  #demo.final-cta .final-cta-corner--br {
    bottom: 1.25rem;
    right: 1.25rem;
    border-bottom-width: 0.5px;
    border-right-width: 0.5px;
  }

  #demo.final-cta .final-cta-glass {
    border: 1px solid rgba(255, 255, 255, 0.55);
    background:
      linear-gradient(
        165deg,
        rgba(255, 255, 255, 0.34) 0%,
        rgba(255, 255, 255, 0.16) 45%,
        rgba(232, 238, 248, 0.12) 100%
      );
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.55) inset,
      0 -1px 0 rgba(0, 51, 160, 0.03) inset,
      0 12px 40px rgba(0, 51, 160, 0.06),
      0 28px 64px rgba(10, 22, 40, 0.05);
    backdrop-filter: blur(14px) saturate(1.25);
    -webkit-backdrop-filter: blur(14px) saturate(1.25);
  }

  #demo.final-cta .final-cta-live {
    animation: demo-live 1.3s ease-in-out infinite;
  }

  #demo.final-cta .final-cta-primary .final-cta-arrow {
    transition: transform 0.25s ease;
  }

  #demo.final-cta .final-cta-primary:hover .final-cta-arrow {
    transform: translateX(3px);
  }

  @keyframes demo-wash {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 0.55;
    }
  }

  @keyframes demo-wash-alt {
    0%,
    100% {
      opacity: 0.35;
      transform: translate(0, 0);
    }
    50% {
      opacity: 0.5;
      transform: translate(-4%, -3%);
    }
  }

  @keyframes demo-lattice {
    to {
      background-position: 28px 28px;
    }
  }

  @keyframes demo-spin {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(360deg);
    }
  }

  @keyframes demo-spin-rev {
    from {
      transform: translate(-50%, -50%) rotate(0deg);
    }
    to {
      transform: translate(-50%, -50%) rotate(-360deg);
    }
  }

  @keyframes demo-spark-a {
    0%,
    100% {
      transform: translate(0, 0);
      opacity: 0.35;
    }
    25% {
      transform: translate(12px, -18px);
      opacity: 0.85;
    }
    55% {
      transform: translate(-8px, -28px);
      opacity: 0.55;
    }
    80% {
      transform: translate(6px, -10px);
      opacity: 0.75;
    }
  }

  @keyframes demo-spark-b {
    0%,
    100% {
      transform: translate(0, 0);
      opacity: 0.4;
    }
    30% {
      transform: translate(-14px, 10px);
      opacity: 0.8;
    }
    60% {
      transform: translate(10px, 22px);
      opacity: 0.5;
    }
    85% {
      transform: translate(-6px, 8px);
      opacity: 0.7;
    }
  }

  @keyframes demo-spark-c {
    0%,
    100% {
      transform: translate(0, 0);
      opacity: 0.3;
    }
    20% {
      transform: translate(8px, 14px);
      opacity: 0.7;
    }
    50% {
      transform: translate(-16px, 4px);
      opacity: 0.9;
    }
    75% {
      transform: translate(4px, -12px);
      opacity: 0.45;
    }
  }

  @keyframes demo-trace {
    0% {
      left: -30%;
      opacity: 0;
    }
    15% {
      opacity: 1;
    }
    85% {
      opacity: 1;
    }
    100% {
      left: 100%;
      opacity: 0;
    }
  }

  @keyframes demo-live {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #demo.final-cta .final-cta-wash--blue,
    #demo.final-cta .final-cta-wash--green,
    #demo.final-cta .final-cta-lattice,
    #demo.final-cta .final-cta-orbit--outer,
    #demo.final-cta .final-cta-orbit--mid,
    #demo.final-cta .final-cta-orbit--inner,
    #demo.final-cta .final-cta-spark,
    #demo.final-cta .final-cta-trace::after,
    #demo.final-cta .final-cta-live {
      animation: none !important;
    }

    #demo.final-cta .final-cta-orbit--outer,
    #demo.final-cta .final-cta-orbit--mid,
    #demo.final-cta .final-cta-orbit--inner {
      transform: translate(-50%, -50%);
    }
  }
</style>
