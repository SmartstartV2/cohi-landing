---
import Container from './ui/Container.astro';
---

<section class="border-b border-line bg-canvas py-8 sm:py-10" aria-label="Positioning">
  <Container>
    <p
      class="mx-auto max-w-2xl text-center font-display text-xl font-medium leading-snug tracking-tight text-ink text-balance sm:text-2xl"
      data-reveal
    >
      Built for mortgage executives who already have LOS, CRM, and finance data&mdash;and still
      can&rsquo;t get a single trustworthy read on what changed this week.
    </p>
  </Container>
</section>
