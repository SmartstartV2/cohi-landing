---
import Container from './ui/Container.astro';
import Badge from './ui/Badge.astro';

const pills = [
  'Mortgage-focused intelligence',
  'AI-assisted analysis',
  'Executive-ready insights',
  'Secure lender data environment',
  'Operational signal detection',
];
---

<section class="border-b border-line bg-canvas py-12 sm:py-14" aria-label="Positioning">
  <Container>
    <p
      class="mx-auto max-w-3xl text-center text-base leading-relaxed text-ink-muted sm:text-lg"
      data-reveal
    >
      Designed for mortgage leadership teams that need clarity across production, operations,
      profitability, risk, and performance.
    </p>
    <ul class="mt-8 flex flex-wrap items-center justify-center gap-2.5" data-reveal>
      {
        pills.map((pill) => (
          <li>
            <Badge>{pill}</Badge>
          </li>
        ))
      }
    </ul>
  </Container>
</section>
