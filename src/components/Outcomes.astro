---
import Container from './ui/Container.astro';
import SectionHeading from './ui/SectionHeading.astro';

const steps = [
  {
    title: 'See what moved',
    body: 'Surface overnight shifts across pull-through, fallout, late closings, and LO tiers—ranked Critical to Context, not buried in dashboards.',
  },
  {
    title: 'Know why it moved',
    body: 'Tie each signal to the drivers behind it—cycle time, borrower conditions, concentration risk—before the first leadership call.',
  },
  {
    title: 'Lock the priority',
    body: 'Align on the few areas with the most leverage on fallout, production, and margin—so the team leads one move, not ten debates.',
  },
];
---

<section id="outcomes" class="scroll-mt-20 bg-surface py-20 sm:py-24">
  <Container>
    <SectionHeading
      title="Signals. Not Noise."
      description="Cohi converts your lender DNA and production data into a shared morning loop: detect the shift, understand the driver, and lock the priority leadership should decide on."
    />

    <div class="outcomes-loop relative mt-12 lg:mt-14" data-outcomes-loop>
      <div
        class="pointer-events-none absolute left-[11px] top-3 bottom-3 w-px bg-line lg:left-[0.75rem] lg:right-[calc(33.333%-0.75rem)] lg:top-[0.75rem] lg:bottom-auto lg:h-px lg:w-auto"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute left-[11px] top-3 bottom-3 w-px origin-top scale-y-0 bg-accent lg:left-[0.75rem] lg:right-[calc(33.333%-0.75rem)] lg:top-[0.75rem] lg:bottom-auto lg:h-px lg:w-auto lg:origin-left lg:scale-x-0 lg:scale-y-100"
        data-outcomes-progress
        aria-hidden="true"
      >
      </div>

      <ol class="relative m-0 grid list-none gap-10 p-0 lg:grid-cols-3 lg:gap-8 xl:gap-10">
        {
          steps.map((item, i) => (
            <li class="relative flex gap-4 lg:flex-col lg:gap-0" data-outcomes-step>
              <span
                class="relative z-10 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-accent/25 bg-surface text-[11px] font-semibold tracking-wide text-accent lg:mb-5"
              >
                {String(i + 1).padStart(2, '0')}
              </span>
              <div class="min-w-0 pt-0.5 lg:pt-0">
                <h3 class="font-display text-xl font-semibold tracking-tight text-ink sm:text-[1.35rem]">
                  {item.title}
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-ink-muted sm:text-[15px]">{item.body}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    <p
      class="mt-10 max-w-2xl border-l-2 border-accent/35 pl-4 text-sm leading-relaxed text-ink-muted sm:mt-12 sm:text-base"
      data-reveal
    >
      <span class="font-semibold text-ink">Act from one brief.</span>
      Executives, managers, and operators share the same ranked signals—so debate ends and decisions start.
    </p>
  </Container>
</section>
