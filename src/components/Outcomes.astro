---
import Container from './ui/Container.astro';
import SectionHeading from './ui/SectionHeading.astro';

const roles = [
  {
    seat: 'Executive',
    focus: 'Morning priority',
    body: 'Open the Daily Brief for the Critical call—fallout, late closings, and what can wait until after coffee.',
    uses: 'Cohi Insights',
    detail: 'Critical first',
  },
  {
    seat: 'Operations',
    focus: 'Where to intervene',
    body: 'Trace drivers behind pull-through slippage—cycle time, conditions, branch pressure—before the ops huddle.',
    uses: 'Fallout & Pull-Through',
    detail: 'Drivers in view',
  },
  {
    seat: 'Production',
    focus: 'Who carries the load',
    body: 'See which originators are Top Tier versus stalling, so coaching and capacity follow the signal—not last month’s report.',
    uses: 'TopTiering®',
    detail: 'Coach from rank',
  },
];
---

<section id="outcomes" class="scroll-mt-20 bg-surface py-20 sm:py-24">
  <Container>
    <SectionHeading
      eyebrow="Leadership"
      title="One brief. Every leadership seat."
      description="Executives, ops, and production leaders work from the same ranked morning signal—each with a clear job when the brief lands."
    />

    <div
      class="outcomes-roles relative mt-12 overflow-hidden rounded-2xl border border-line bg-[linear-gradient(180deg,#fbfcfd_0%,#ffffff_42%)] shadow-card lg:mt-14"
      data-outcomes-loop
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_70%_55%_at_50%_0%,rgba(0,51,160,0.05),transparent_55%)]"
        aria-hidden="true"
      >
      </div>

      <div
        class="relative flex flex-wrap items-center justify-between gap-3 border-b border-line px-5 py-3.5 sm:px-6"
      >
        <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-ink-subtle">
          Shared Daily Brief
        </p>
        <p class="text-[11px] font-medium text-accent">
          Same lender DNA · ranked urgency
        </p>
      </div>

      <ul
        class="relative m-0 grid list-none divide-y divide-line p-0 lg:grid-cols-3 lg:divide-x lg:divide-y-0"
      >
        {
          roles.map((role, index) => (
            <li
              class="relative flex flex-col px-5 py-7 sm:px-6 sm:py-8"
              data-outcomes-step
            >
              <div class="flex items-center justify-between gap-3">
                <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-accent">
                  {role.seat}
                </p>
                <span
                  class="font-display text-sm font-semibold tabular-nums tracking-tight text-ink-subtle/70"
                  aria-hidden="true"
                >
                  {String(index + 1).padStart(2, '0')}
                </span>
              </div>

              <h3 class="mt-5 font-display text-xl font-semibold tracking-tight text-ink sm:text-[1.4rem]">
                {role.focus}
              </h3>
              <p class="mt-2.5 flex-1 text-sm leading-relaxed text-ink-muted sm:text-[15px]">
                {role.body}
              </p>

              <div class="mt-6 flex flex-wrap items-center gap-x-2 gap-y-1 border-t border-line/80 pt-4">
                <span class="text-[11px] font-semibold text-ink">{role.uses}</span>
                <span class="text-[10px] text-line-strong" aria-hidden="true">
                  ·
                </span>
                <span class="text-[11px] text-ink-subtle">{role.detail}</span>
              </div>
            </li>
          ))
        }
      </ul>
    </div>

    <p
      class="mt-8 max-w-2xl text-sm leading-relaxed text-ink-muted sm:mt-10 sm:text-[15px]"
      data-reveal
    >
      <span class="font-semibold text-ink">Same lender DNA. Shared urgency.</span>
      {' '}
      Debate ends when every seat starts from Critical—not a private dashboard.
    </p>
  </Container>
</section>
