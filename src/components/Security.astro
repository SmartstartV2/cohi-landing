---
import Container from './ui/Container.astro';
import Card from './ui/Card.astro';
import SectionHeading from './ui/SectionHeading.astro';

const trusts = [
  'Secure data handling',
  'Role-based access',
  'Responsible AI workflows',
  'Enterprise-ready controls',
  'Permission-aware visibility',
  'Mortgage business context',
];
---

<section class="border-b border-line bg-surface py-20 sm:py-24">
  <Container>
    <SectionHeading
      title="Built for sensitive lender data."
      description="Mortgage data is sensitive. Coheus is designed as a secure executive intelligence environment with responsible AI workflows, role-based visibility, and enterprise-ready controls."
    />

    <div class="mt-12 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        trusts.map((item) => (
          <Card class="h-full !py-5" data-reveal>
            <div class="flex items-center gap-3">
              <span
                class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent-soft text-accent"
                aria-hidden="true"
              >
                <svg class="h-3.5 w-3.5" viewBox="0 0 14 14" fill="none">
                  <path
                    d="M7 1.5 L11.5 3.5 V7.2 C11.5 9.8 9.6 12 7 12.5 C4.4 12 2.5 9.8 2.5 7.2 V3.5 L7 1.5 Z"
                    stroke="currentColor"
                    stroke-width="1.3"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <h3 class="text-sm font-semibold text-ink sm:text-[15px]">{item}</h3>
            </div>
          </Card>
        ))
      }
    </div>
  </Container>
</section>
