---
import Container from './ui/Container.astro';
import SectionHeading from './ui/SectionHeading.astro';

const hero = {
  title: 'Data stays yours',
  body: 'No silent warehouse sync into model training corpora. Production and market data power the Daily Brief—they don’t become training fodder.',
  icon: 'lock' as const,
};

const pillars = [
  {
    title: 'Access by role',
    body: 'Executives, ops, and production see the ranked signal for their seat—not one flat dump.',
    icon: 'roles' as const,
    tone: 'navy' as const,
  },
  {
    title: 'Decision support',
    body: 'Cohi advises with Critical signals and drivers. It doesn’t silently automate lender decisions.',
    icon: 'guide' as const,
    tone: 'warning' as const,
  },
  {
    title: 'Responsible AI',
    body: 'Grounded in your lender DNA—explanations leaders can trust before coffee.',
    icon: 'spark' as const,
    tone: 'success' as const,
  },
];

const toneWash: Record<(typeof pillars)[number]['tone'], string> = {
  navy: 'bg-[#e8eef4]/55 border-[#c5d0de]/80 hover:border-navy/30',
  warning: 'bg-[#f8efe2]/50 border-[#e5d4b8]/80 hover:border-warning/35',
  success: 'bg-[#e7f3ec]/55 border-[#b8d9c6]/80 hover:border-success/35',
};

const toneIcon: Record<(typeof pillars)[number]['tone'], string> = {
  navy: 'text-navy',
  warning: 'text-warning',
  success: 'text-success',
};
---

<section id="security" class="scroll-mt-20 bg-surface py-20 sm:py-24" data-security>
  <Container>
    <SectionHeading
      eyebrow="Trust"
      title="Built for sensitive lender data."
      description="Mortgage data is sensitive. Coheus is a secure executive intelligence environment—responsible AI, role-based visibility, and clear boundaries around how your data is used."
    />

    <div class="security-pillars mt-10 sm:mt-12" data-security-panel>
      <!-- Hero principle -->
      <article
        class="security-hero relative overflow-hidden rounded-2xl border border-accent/20 bg-[linear-gradient(135deg,#eef2f8_0%,#ffffff_48%,#f7fafb_100%)] p-6 shadow-card ring-1 ring-accent/10 sm:p-8 lg:p-10"
        data-security-row
        data-security-hero
      >
        <div
          class="pointer-events-none absolute -right-10 -top-16 h-56 w-56 rounded-full bg-accent/[0.07]"
          aria-hidden="true"
        >
        </div>
        <div
          class="pointer-events-none absolute -bottom-20 -left-10 h-40 w-40 rounded-full bg-accent/[0.04]"
          aria-hidden="true"
        >
        </div>

        <div class="relative flex flex-col gap-6 sm:flex-row sm:items-start sm:gap-8 lg:gap-12">
          <span
            class="security-icon flex h-14 w-14 shrink-0 items-center justify-center text-accent sm:h-16 sm:w-16"
            aria-hidden="true"
          >
            <svg class="h-9 w-9 sm:h-10 sm:w-10" viewBox="0 0 16 16" fill="none">
              <rect
                x="3.5"
                y="7"
                width="9"
                height="6.5"
                rx="1.5"
                stroke="currentColor"
                stroke-width="1.25"
              />
              <path
                d="M5.5 7 V5.2 A2.5 2.5 0 0 1 10.5 5.2 V7"
                stroke="currentColor"
                stroke-width="1.25"
                stroke-linecap="round"
              />
            </svg>
          </span>

          <div class="min-w-0 flex-1">
            <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-accent">
              Core posture
            </p>
            <h3 class="mt-2 font-display text-2xl font-semibold tracking-tight text-ink sm:text-3xl lg:text-[2rem]">
              {hero.title}
            </h3>
            <p class="mt-3 max-w-2xl text-base leading-relaxed text-ink-muted sm:text-lg">
              {hero.body}
            </p>
          </div>
        </div>
      </article>

      <!-- Supporting pillars -->
      <ul class="mt-4 grid list-none gap-4 p-0 m-0 sm:mt-5 sm:grid-cols-3 sm:gap-5">
        {
          pillars.map((item) => (
            <li
              class:list={[
                'security-pillar group relative overflow-hidden rounded-2xl border p-5 transition-[border-color,box-shadow,transform] duration-300 hover:-translate-y-0.5 hover:shadow-card sm:p-5',
                toneWash[item.tone],
              ]}
              data-security-row
            >
              <span
                class:list={[
                  'security-icon flex h-9 w-9 items-center justify-center transition-transform duration-300 group-hover:-translate-y-0.5',
                  toneIcon[item.tone],
                ]}
                aria-hidden="true"
              >
                {item.icon === 'roles' && (
                  <svg class="h-5 w-5" viewBox="0 0 16 16" fill="none">
                    <circle cx="6" cy="5.5" r="2" stroke="currentColor" stroke-width="1.35" />
                    <circle cx="11" cy="6.5" r="1.6" stroke="currentColor" stroke-width="1.35" />
                    <path
                      d="M2.5 12.5 C2.5 10.5 4 9.2 6 9.2 C8 9.2 9.5 10.5 9.5 12.5"
                      stroke="currentColor"
                      stroke-width="1.35"
                      stroke-linecap="round"
                    />
                    <path
                      d="M9.8 12.5 C10 11 11.2 10.2 12.5 10.2 C13.6 10.2 14.5 10.8 14.5 12.5"
                      stroke="currentColor"
                      stroke-width="1.35"
                      stroke-linecap="round"
                    />
                  </svg>
                )}
                {item.icon === 'guide' && (
                  <svg class="h-5 w-5" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.35" />
                    <path
                      d="M8 4.5 V8.2 L10.5 10"
                      stroke="currentColor"
                      stroke-width="1.35"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                )}
                {item.icon === 'spark' && (
                  <svg class="h-5 w-5" viewBox="0 0 16 16" fill="none">
                    <path
                      d="M8 2.5 V4.2 M8 11.8 V13.5 M2.5 8 H4.2 M11.8 8 H13.5 M4.2 4.2 L5.3 5.3 M10.7 10.7 L11.8 11.8 M11.8 4.2 L10.7 5.3 M5.3 10.7 L4.2 11.8"
                      stroke="currentColor"
                      stroke-width="1.35"
                      stroke-linecap="round"
                    />
                    <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.35" />
                  </svg>
                )}
              </span>
              <h3 class="mt-3 font-display text-lg font-semibold tracking-tight text-ink">
                {item.title}
              </h3>
              <p class="mt-1.5 text-sm leading-relaxed text-ink-muted">{item.body}</p>
            </li>
          ))
        }
      </ul>
    </div>

    <p
      class="mt-8 max-w-2xl text-sm leading-relaxed text-ink-muted sm:mt-10 sm:text-[15px]"
      data-reveal
    >
      <span class="font-semibold text-ink">Questions on security?</span>
      {' '}
      Talk with us about access, data boundaries, and how Cohi fits your environment—
      <a
        href="mailto:sales@coheus.com"
        class="font-semibold text-accent transition-colors hover:text-accent-hover"
      >
        sales@coheus.com
      </a>.
    </p>
  </Container>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    .security-pillar {
      transition: none;
    }

    .security-pillar:hover {
      transform: none;
    }
  }
</style>
