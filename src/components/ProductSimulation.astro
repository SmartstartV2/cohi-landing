---
import Container from './ui/Container.astro';

const sources = [
  'Pull-Through',
  'Fallout',
  'Closings',
  'LO Production',
  'Margin',
  'Market Rates',
];

const SPARK_W = 56;
const SPARK_H = 22;

function areaPaths(values: number[], width: number, height: number) {
  const max = Math.max(...values);
  const min = Math.min(...values);
  const range = Math.max(max - min, 1);
  const coords = values.map((value, index) => {
    const x = (index / (values.length - 1)) * width;
    const y = height - ((value - min) / range) * (height - 3) - 1.5;
    return { x, y };
  });
  const line = coords
    .map((point, index) => `${index === 0 ? 'M' : 'L'}${point.x.toFixed(1)} ${point.y.toFixed(1)}`)
    .join(' ');
  const area = `${line} L${width} ${height} L0 ${height} Z`;
  return { line, area };
}

function barRects(values: number[], width: number, height: number) {
  const count = values.length;
  const gap = 0.9;
  const barW = (width - gap * (count - 1)) / count;
  const max = Math.max(...values, 1);
  return values.map((value, index) => {
    const h = Math.max((value / max) * height, 2);
    return {
      x: index * (barW + gap),
      y: height - h,
      w: barW,
      h,
    };
  });
}

const pulseMetrics = [
  {
    key: 'pipeline',
    label: 'Pull-Through',
    idleValue: '72%',
    idleStatus: 'On track',
    tone: 'teal',
    icon: 'pipeline',
    sparkType: 'area' as const,
    spark: [40, 42, 41, 43, 44, 45, 44, 46, 47, 48],
  },
  {
    key: 'fallout',
    label: 'Fallout Risk',
    idleValue: '$0',
    idleStatus: 'Clear',
    tone: 'amber',
    icon: 'risk',
    sparkType: 'area' as const,
    spark: [12, 14, 13, 15, 14, 16, 15, 14, 13, 12],
  },
  {
    key: 'cost',
    label: 'Late Closings',
    idleValue: '12',
    idleStatus: 'Steady',
    tone: 'navy',
    icon: 'cost',
    sparkType: 'bars' as const,
    spark: [18, 20, 16, 22, 19, 21, 17, 20, 18, 19, 17, 18],
  },
  {
    key: 'margin',
    label: 'LO Concentration',
    idleValue: '7',
    idleStatus: 'Top tier',
    tone: 'green',
    icon: 'margin',
    sparkType: 'bars' as const,
    spark: [22, 24, 20, 26, 23, 25, 21, 24, 22, 23, 21, 22],
  },
];

const pulseMetricsRendered = pulseMetrics.map((metric, index) => {
  if (metric.sparkType === 'area') {
    const { line, area } = areaPaths(metric.spark, SPARK_W, SPARK_H);
    return { ...metric, line, area, bars: null as null, gradId: `sim-kpi-ssr-${index}` };
  }
  return {
    ...metric,
    line: '',
    area: '',
    bars: barRects(metric.spark, SPARK_W, SPARK_H),
    gradId: `sim-kpi-ssr-${index}`,
  };
});

const watchItems = [
  {
    id: 'fallout',
    severity: 'Critical',
    title: '$23M closing & fallout exposure',
    detail: '67 late · 74 fallout risk',
    orderIdle: 2,
    orderActive: 1,
    icon: 'risk',
  },
  {
    id: 'cost',
    severity: 'Needs Attention',
    title: 'Bottom-tier originators stalling',
    detail: '35% with <1 app by mid-month',
    orderIdle: 1,
    orderActive: 2,
    icon: 'cost',
  },
  {
    id: 'margin',
    severity: 'Context & Trends',
    title: 'Govvie mix drifting off target',
    detail: '12% decline · profit impact rising',
    orderIdle: 3,
    orderActive: 3,
    icon: 'margin',
  },
];

const prompts = [
  'Which loans are at risk of fallout this week?',
  'Who is in the bottom tier of production?',
];

const urgencyStack = [
  { id: 'critical', label: 'Critical', detail: 'Immediate Action Required', step: 5 },
  { id: 'attention', label: 'Needs Attention', detail: 'Monitor Closely', step: 6 },
  { id: 'working', label: "What's Working", detail: 'Pull-through stabilizing', step: 7 },
  { id: 'context', label: 'Context & Trends', detail: 'Govvie mix · rates', step: 8 },
];

const toneClass: Record<string, string> = {
  teal: 'bg-accent-soft text-accent',
  amber: 'bg-[#f8efe2] text-warning',
  navy: 'bg-[#e8eef4] text-navy',
  green: 'bg-[#e7f3ec] text-success',
};

const severityClass: Record<string, string> = {
  Critical: 'bg-[#f8efe2] text-warning',
  'Needs Attention': 'bg-[#e8eef4] text-navy',
  'Context & Trends': 'bg-accent-soft text-accent',
};
---

<section
  id="how-it-works"
  class="relative scroll-mt-20 bg-[linear-gradient(180deg,#ffffff_0%,#ffffff_18%,#f4f6fa_42%,#f4f6fa_100%)] pb-6 pt-0 flow-root sm:pb-8 lg:pb-10"
  aria-label="How Coheus works"
>
  <h2 id="exec-center-heading" class="sr-only">From lender signals to executive action</h2>
  <Container>
    <!-- Negative margin is contained by flow-root so only this card peeks — section bg stays put -->
    <div
      class="sim relative z-10 mx-auto -mt-[120px] max-w-4xl pb-4 sm:pb-6"
      data-sim
      data-scene="1"
      role="region"
      aria-label="Animated Cohi Insights daily briefing showing how Coheus turns lender signals into prioritized executive action"
    >
      <p
        class="sim-caption mb-4 min-h-[2.75rem] text-center text-sm font-medium tracking-wide text-accent sm:mb-5 sm:min-h-[1.75rem] sm:text-base"
        data-sim-caption
        aria-live="polite"
      >
        <span data-sim-caption-text>Cohi connects your lender DNA to what matters today.</span><span
          class="sim-caption-caret"
          data-sim-caption-caret
          aria-hidden="true"></span>
      </p>

      <div class="sim-stage relative">
        <div
          class="sim-frame shadow-elevated relative rounded-2xl border border-line bg-surface ring-1 ring-accent/5"
        >
          <!-- Chrome -->
          <div
            class="flex items-center justify-between gap-3 border-b border-line bg-[linear-gradient(180deg,#fbfcfd_0%,#ffffff_100%)] px-4 py-3 sm:px-5"
          >
            <div class="flex items-center gap-2.5">
              <span
                class="flex h-7 w-7 items-center justify-center rounded-lg bg-navy text-[11px] font-bold text-white"
                aria-hidden="true"
              >
                C
              </span>
              <div>
                <p class="text-xs font-semibold tracking-tight text-ink">Cohi Insights</p>
                <p class="text-[10px] text-ink-subtle">Daily Briefing · Signals. Not Noise.</p>
              </div>
            </div>
            <div
              class="inline-flex items-center gap-1.5 rounded-full border border-line bg-canvas px-2.5 py-1"
            >
              <span class="sim-live-dot h-1.5 w-1.5 rounded-full bg-success" aria-hidden="true"></span>
              <p class="text-[10px] font-semibold uppercase tracking-[0.12em] text-ink-subtle" data-sim-clock>
                Live
              </p>
            </div>
          </div>

          <!-- Scene 1: business-domain chips -->
          <div
            class="sim-sources pointer-events-none absolute inset-x-0 top-14 z-30 flex flex-wrap items-start justify-center gap-1.5 px-3 pt-3 sm:gap-2 sm:px-5"
            data-sim-sources
            aria-hidden="true"
          >
            {
              sources.map((source, i) => (
                <span
                  class="sim-source inline-flex items-center gap-1.5 rounded-full border border-accent/15 bg-surface px-2.5 py-1 text-[10px] font-medium text-ink shadow-card sm:px-3 sm:py-1.5 sm:text-xs"
                  style={`--i: ${i}`}
                  data-sim-source
                >
                  <span class="h-1.5 w-1.5 rounded-full bg-accent/70" />
                  {source}
                </span>
              ))
            }
          </div>

          <div
            class="sim-body relative bg-[linear-gradient(180deg,#eef2f8_0%,#f4f6fa_45%,#f8fafb_100%)] p-3 sm:min-h-[23rem] sm:p-5"
          >
            <!-- Morning Pulse -->
            <div class="mb-3 sm:mb-4" data-sim-pulse>
              <div class="mb-2.5 flex items-center justify-between gap-3 px-0.5">
                <div class="flex items-center gap-2">
                  <span
                    class="flex h-5 w-5 items-center justify-center rounded-md bg-accent-soft text-accent"
                    aria-hidden="true"
                  >
                    <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none">
                      <path
                        d="M1.5 8.5 L4 5.5 L6.2 7.2 L10.5 2.5"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"></path>
                    </svg>
                  </span>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-ink-subtle">
                    Morning Pulse
                  </p>
                </div>
                <p
                  class="rounded-full bg-surface px-2 py-0.5 text-[10px] font-medium text-ink-subtle ring-1 ring-line"
                  data-sim-pulse-note
                >
                  Monitoring
                </p>
              </div>
              <div class="grid grid-cols-2 gap-2 sm:grid-cols-4 sm:gap-2.5">
                {
                  pulseMetricsRendered.map((metric, i) => (
                    <div
                      class="sim-kpi rounded-xl border border-line bg-surface p-3 shadow-[0_1px_0_rgb(11_27_43/0.03)]"
                      style={`--i: ${i}`}
                      data-sim-kpi={metric.key}
                    >
                      <div class="flex items-start justify-between gap-2">
                        <span
                          class:list={[
                            'flex h-7 w-7 items-center justify-center rounded-lg',
                            toneClass[metric.tone],
                          ]}
                          aria-hidden="true"
                        >
                          {metric.icon === 'pipeline' && (
                            <svg class="h-3.5 w-3.5" viewBox="0 0 14 14" fill="none">
                              <path
                                d="M2 10 V4 M5.5 10 V6 M9 10 V3 M12 10 V7"
                                stroke="currentColor"
                                stroke-width="1.6"
                                stroke-linecap="round"
                              />
                            </svg>
                          )}
                          {metric.icon === 'risk' && (
                            <svg class="h-3.5 w-3.5" viewBox="0 0 14 14" fill="none">
                              <path
                                d="M7 2.2 L12.2 11.5 H1.8 Z"
                                stroke="currentColor"
                                stroke-width="1.4"
                                stroke-linejoin="round"
                              />
                              <path
                                d="M7 5.5 V8.2 M7 9.8 V10.1"
                                stroke="currentColor"
                                stroke-width="1.4"
                                stroke-linecap="round"
                              />
                            </svg>
                          )}
                          {metric.icon === 'cost' && (
                            <svg class="h-3.5 w-3.5" viewBox="0 0 14 14" fill="none">
                              <circle cx="7" cy="7" r="4.6" stroke="currentColor" stroke-width="1.4" />
                              <path
                                d="M7 4.4 V9.6 M5.4 5.5 C5.4 4.8 6.1 4.4 7 4.4 C7.9 4.4 8.6 4.8 8.6 5.5 C8.6 6.2 7.9 6.5 7 6.5 C6.1 6.5 5.4 6.9 5.4 7.6 C5.4 8.3 6.1 8.7 7 8.7 C7.9 8.7 8.6 8.3 8.6 7.6"
                                stroke="currentColor"
                                stroke-width="1.2"
                                stroke-linecap="round"
                              />
                            </svg>
                          )}
                          {metric.icon === 'margin' && (
                            <svg class="h-3.5 w-3.5" viewBox="0 0 14 14" fill="none">
                              <path
                                d="M2.5 9.5 L5.5 6.5 L7.5 8.2 L11.5 3.8"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                              <path
                                d="M9 3.8 H11.5 V6.2"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                            </svg>
                          )}
                        </span>
                        <div class="sim-kpi-spark-wrap shrink-0" data-sim-kpi-spark aria-hidden="true">
                          {metric.sparkType === 'area' ? (
                            <svg
                              class="sim-kpi-spark"
                              viewBox={`0 0 ${SPARK_W} ${SPARK_H}`}
                              width={SPARK_W}
                              height={SPARK_H}
                            >
                              <defs>
                                <linearGradient id={metric.gradId} x1="0" y1="0" x2="0" y2="1">
                                  <stop offset="0%" stop-color="#3366b3" stop-opacity="0.35" />
                                  <stop offset="100%" stop-color="#3366b3" stop-opacity="0" />
                                </linearGradient>
                              </defs>
                              <path
                                class="sim-kpi-spark-area"
                                d={metric.area}
                                fill={`url(#${metric.gradId})`}
                              />
                              <path
                                class="sim-kpi-spark-line"
                                d={metric.line}
                                fill="none"
                                stroke="#0033a0"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                              />
                            </svg>
                          ) : (
                            <svg
                              class="sim-kpi-spark"
                              viewBox={`0 0 ${SPARK_W} ${SPARK_H}`}
                              width={SPARK_W}
                              height={SPARK_H}
                            >
                              {metric.bars?.map((bar) => (
                                <rect
                                  class="sim-kpi-spark-bar"
                                  x={bar.x.toFixed(2)}
                                  y={bar.y.toFixed(2)}
                                  width={bar.w.toFixed(2)}
                                  height={bar.h.toFixed(2)}
                                  rx="0.4"
                                  fill="#5a7fc4"
                                />
                              ))}
                            </svg>
                          )}
                        </div>
                      </div>
                      <p class="mt-2.5 text-[10px] font-medium leading-snug text-ink-subtle sm:text-[11px]">
                        {metric.label}
                      </p>
                      <div class="mt-1 flex items-baseline justify-between gap-2">
                        <p
                          class="text-sm font-semibold tracking-tight text-ink sm:text-[15px]"
                          data-sim-kpi-value
                        >
                          {metric.idleValue}
                        </p>
                        <p
                          class="truncate text-[10px] font-medium text-ink-subtle"
                          data-sim-kpi-status
                        >
                          {metric.idleStatus}
                        </p>
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>

            <div class="grid gap-3 lg:grid-cols-12 lg:gap-4">
              <!-- Priority queue -->
              <div class="lg:col-span-5" data-sim-panel="signals">
                <div class="rounded-xl border border-line bg-surface p-3.5 shadow-[0_1px_0_rgb(11_27_43/0.03)] sm:p-4">
                  <div class="mb-3 flex items-center justify-between gap-2">
                    <div class="flex items-center gap-2">
                      <span
                        class="flex h-5 w-5 items-center justify-center rounded-md bg-[#f8efe2] text-warning"
                        aria-hidden="true"
                      >
                        <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none">
                          <path
                            d="M6 1.8 L10.5 10 H1.5 Z"
                            stroke="currentColor"
                            stroke-width="1.3"
                            stroke-linejoin="round"></path>
                        </svg>
                      </span>
                      <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-ink-subtle">
                        Ranked by urgency
                      </p>
                    </div>
                    <span
                      class="rounded-full bg-canvas px-2 py-0.5 text-[10px] font-semibold text-ink-subtle ring-1 ring-line"
                      data-sim-queue-badge
                    >
                      Critical first
                    </span>
                  </div>

                  <ul class="sim-watch-list flex min-h-[11.5rem] flex-col gap-2" data-sim-watch-list>
                    {
                      watchItems.map((item, i) => (
                        <li
                          class="sim-watch-item relative overflow-hidden rounded-lg border border-line bg-canvas/80 px-3 py-2.5"
                          style={`--idle: ${item.orderIdle}; --active: ${item.orderActive}; --i: ${i}`}
                          data-sim-watch={item.id}
                          data-severity={item.severity.toLowerCase()}
                        >
                          <span
                            class:list={[
                              'absolute inset-y-0 left-0 w-0.5',
                              item.severity === 'Critical'
                                ? 'bg-warning'
                                : item.severity === 'Needs Attention'
                                  ? 'bg-navy/50'
                                  : 'bg-accent/50',
                            ]}
                            aria-hidden="true"
                          />
                          <div class="flex items-start gap-2.5 pl-1">
                            <span
                              class:list={[
                                'mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-md',
                                toneClass[
                                  item.id === 'fallout' ? 'amber' : item.id === 'cost' ? 'navy' : 'teal'
                                ],
                              ]}
                              aria-hidden="true"
                            >
                              {item.icon === 'risk' && (
                                <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none">
                                  <path
                                    d="M6 1.8 L10.5 10 H1.5 Z"
                                    stroke="currentColor"
                                    stroke-width="1.3"
                                    stroke-linejoin="round"
                                  />
                                </svg>
                              )}
                              {item.icon === 'cost' && (
                                <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none">
                                  <circle cx="6" cy="6" r="3.8" stroke="currentColor" stroke-width="1.2" />
                                </svg>
                              )}
                              {item.icon === 'margin' && (
                                <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none">
                                  <path
                                    d="M2 8.5 L4.5 6 L6.2 7.4 L10 3.5"
                                    stroke="currentColor"
                                    stroke-width="1.3"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                  />
                                </svg>
                              )}
                            </span>
                            <div class="min-w-0 flex-1">
                              <div class="flex items-start justify-between gap-2">
                                <p class="text-xs font-semibold text-ink sm:text-[13px]">{item.title}</p>
                                <span
                                  class:list={[
                                    'shrink-0 rounded-md px-1.5 py-0.5 text-[10px] font-semibold',
                                    severityClass[item.severity],
                                  ]}
                                >
                                  {item.severity}
                                </span>
                              </div>
                              <div class="mt-1 flex flex-wrap items-center gap-x-2 gap-y-0.5">
                                <p class="text-[11px] text-ink-muted">{item.detail}</p>
                                <span class="text-[10px] text-line-strong">·</span>
                                <span
                                  class="sim-watch-status text-[10px] font-medium text-ink-subtle"
                                  data-sim-watch-status
                                >
                                  Open
                                </span>
                              </div>
                            </div>
                          </div>
                        </li>
                      ))
                    }
                  </ul>
                </div>
              </div>

              <!-- Cohi brief -->
              <div class="lg:col-span-7">
                <div
                  class="sim-brief relative min-h-[13.5rem] overflow-hidden rounded-xl border border-accent/20 bg-[linear-gradient(145deg,#eef2f8_0%,#e8eef8_55%,#f7fafb_100%)] p-4 text-ink shadow-[0_1px_2px_rgb(0_51_160_/_0.06),0_10px_28px_rgb(0_51_160_/_0.12)] sm:min-h-[15rem] sm:p-5"
                  data-sim-brief
                >
                  <div
                    class="pointer-events-none absolute -right-10 -top-12 h-36 w-36 rounded-full bg-accent/[0.04] blur-3xl"
                    aria-hidden="true"
                  >
                  </div>
                  <div class="relative flex items-center gap-2.5">
                    <span
                      class="flex h-7 w-7 items-center justify-center rounded-lg bg-accent-soft text-accent ring-1 ring-accent/15"
                      aria-hidden="true"
                    >
                      <svg class="h-3.5 w-3.5" viewBox="0 0 14 14" fill="none">
                        <path
                          d="M7 1.5 V3.2 M7 10.8 V12.5 M1.5 7 H3.2 M10.8 7 H12.5 M3.2 3.2 L4.3 4.3 M9.7 9.7 L10.8 10.8 M10.8 3.2 L9.7 4.3 M4.3 9.7 L3.2 10.8"
                          stroke="currentColor"
                          stroke-width="1.3"
                          stroke-linecap="round"></path>
                        <circle cx="7" cy="7" r="2.2" stroke="currentColor" stroke-width="1.3"></circle>
                      </svg>
                    </span>
                    <div>
                      <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-accent">
                        Cohi Daily Brief
                      </p>
                      <div class="mt-0.5 flex items-center gap-1.5">
                        <span class="sim-pulse-dot h-1.5 w-1.5 rounded-full bg-accent"></span>
                        <p class="text-[10px] text-ink-subtle">Actionable intelligence before coffee</p>
                      </div>
                    </div>
                  </div>
                  <div class="relative mt-3.5 min-h-[8.5rem] sm:min-h-[9.5rem]">
                    <div
                      class="sim-brief-idle absolute inset-0"
                      data-sim-brief-idle
                    >
                      <p class="text-sm leading-relaxed text-ink-muted">
                        Cohi is reviewing your lender DNA—pull-through, fallout, closings, and LO
                        production—for signals that need executive attention this morning.
                      </p>
                      <div
                        class="sim-brief-processing mt-3"
                        aria-hidden="true"
                      >
                        <div class="flex items-center justify-between gap-2">
                          <p class="text-[10px] font-medium text-ink-subtle">Processing signals…</p>
                        </div>
                        <div
                          class="sim-brief-processing-track mt-1.5 h-1 overflow-hidden rounded-full bg-canvas ring-1 ring-line/50"
                        >
                          <span class="sim-brief-processing-bar block h-full rounded-full bg-accent"></span>
                        </div>
                      </div>
                    </div>
                    <div
                      class="sim-brief-active absolute inset-0"
                      data-sim-brief-active
                    >
                      <p class="text-sm leading-relaxed text-ink sm:text-[15px]">
                        Immediate action required: $23M exposure across 67 loans at risk of closing late
                        and 74 at risk of fallout. Longer cycle times and delayed borrower conditions are
                        driving pull-through slippage in the West.
                      </p>
                      <div
                        class="sim-brief-actions-active mt-3 flex flex-wrap gap-2"
                        aria-hidden="true"
                      >
                        <span
                          class="sim-brief-chip sim-brief-chip--primary inline-flex items-center rounded-lg px-2.5 py-1.5 text-[10px] font-semibold"
                        >
                          View at-risk loans
                        </span>
                        <span
                          class="sim-brief-chip inline-flex items-center rounded-lg border border-line bg-surface px-2.5 py-1.5 text-[10px] font-semibold text-ink-muted"
                        >
                          Ask Cohi why
                        </span>
                      </div>
                    </div>
                    <p
                      class="sim-brief-resolved absolute inset-0 text-sm leading-relaxed text-ink sm:text-[15px]"
                      data-sim-brief-resolved
                    >
                      Critical is in focus. Needs Attention and Context stay ranked—Signals. Not
                      Noise.
                    </p>
                  </div>
                  <div
                    class="sim-brief-actions relative mt-3 flex flex-wrap gap-2"
                    data-sim-brief-actions
                    aria-hidden="true"
                  >
                    <span
                      class="sim-brief-chip sim-brief-chip--primary inline-flex items-center rounded-lg px-2.5 py-1.5 text-[10px] font-semibold"
                    >
                      View Critical list
                    </span>
                    <span
