---
import Container from './ui/Container.astro';
import SectionHeading from './ui/SectionHeading.astro';

const sources = [
  'Production',
  'Pipeline',
  'Operations',
  'Profitability',
  'Risk',
  'Productivity',
];

const pulseMetrics = [
  { key: 'pipeline', label: 'Pipeline Health', idle: 'Stable' },
  { key: 'fallout', label: 'Fallout Risk', idle: 'Clear' },
  { key: 'cost', label: 'Cost Per Loan', idle: 'Steady' },
  { key: 'margin', label: 'Margin / Profitability', idle: 'Stable' },
];

const secondarySignals = [
  {
    title: 'Cost per loan rising',
    area: 'Origination',
    stake: 'Unit cost pressure',
  },
  {
    title: 'Margin pressure building',
    area: 'Pricing & secondary',
    stake: 'Spread protection',
  },
];

const prompts = [
  'Where should leadership focus today?',
  'What changed across the pipeline this week?',
  'Why is cost per loan increasing?',
];

const focusItems = [
  '1 high-priority signal',
  'West Region under review',
  '1 recommended action',
  'Owner assigned',
  'Outcome tracking started',
];
---

<section
  id="how-it-works"
  class="scroll-mt-20 border-b border-line bg-surface py-16 sm:py-20 lg:py-24"
  aria-labelledby="exec-center-heading"
>
  <Container>
    <SectionHeading
      align="center"
      class="mb-10 sm:mb-12"
      headingId="exec-center-heading"
      title="From business signals to executive action."
      description="Coheus analyzes mortgage business data in the background, surfaces the signals that deserve attention, explains the drivers, and helps leadership focus on the next best action."
    />

    <div
      class="sim relative mx-auto max-w-4xl"
      data-sim
      data-scene="1"
      role="region"
      aria-label="Animated Executive Center simulation showing how Coheus turns mortgage data into prioritized executive action"
    >
      <p
        class="sim-caption mb-4 min-h-[1.5rem] text-center text-sm font-medium tracking-wide text-accent transition-opacity duration-500 sm:mb-5 sm:text-base"
        data-sim-caption
        aria-live="polite"
      >
        Coheus connects the signals behind your mortgage business.
      </p>

      <div class="sim-frame shadow-elevated relative overflow-hidden rounded-2xl border border-line bg-surface">
        <div class="flex items-center justify-between border-b border-line px-4 py-3 sm:px-5">
          <div class="flex items-center gap-2" aria-hidden="true">
            <span class="h-2.5 w-2.5 rounded-full bg-line-strong"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-line-strong"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-line-strong"></span>
          </div>
          <p class="text-xs font-medium text-ink-subtle">Coheus · Executive Center</p>
          <p class="text-xs text-ink-subtle tabular-nums" data-sim-clock>Live</p>
        </div>

        <!-- Scene 1: business-domain chips -->
        <div
          class="sim-sources pointer-events-none absolute inset-x-0 top-12 z-30 flex flex-wrap items-start justify-center gap-1.5 px-3 pt-3 sm:gap-2 sm:px-5"
          data-sim-sources
          aria-hidden="true"
        >
          {
            sources.map((source, i) => (
              <span
                class="sim-source rounded-full border border-line bg-surface px-2.5 py-1 text-[10px] font-medium text-ink shadow-card sm:px-3 sm:py-1.5 sm:text-xs"
                style={`--i: ${i}`}
                data-sim-source
              >
                {source}
              </span>
            ))
          }
        </div>

        <div class="relative bg-canvas/60 p-3 sm:p-5">
          <!-- Business Pulse: thin CEO strip -->
          <div class="sim-pulse-strip mb-3 sm:mb-4" data-sim-pulse>
            <div class="mb-2 flex items-center justify-between gap-3 px-0.5">
              <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-ink-subtle">
                Business Pulse
              </p>
              <p class="text-[11px] text-ink-subtle" data-sim-pulse-note>Monitoring</p>
            </div>
            <div class="grid grid-cols-2 gap-2 sm:grid-cols-4">
              {
                pulseMetrics.map((metric) => (
                  <div
                    class="sim-kpi rounded-xl border border-line bg-surface px-3 py-2.5"
                    data-sim-kpi={metric.key}
                  >
                    <p class="text-[10px] font-medium leading-snug text-ink-subtle sm:text-[11px]">
                      {metric.label}
                    </p>
                    <p
                      class="mt-1 text-sm font-semibold tracking-tight text-ink sm:text-[15px]"
                      data-sim-kpi-value
                    >
                      {metric.idle}
                    </p>
                    <div class="mt-2 h-1 overflow-hidden rounded-full bg-canvas" aria-hidden="true">
                      <div class="sim-kpi-fill h-full w-2/5 rounded-full bg-accent/70" data-sim-kpi-fill>
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- CEO morning brief: Signal → Cohi → Action -->
          <div class="grid gap-3 lg:grid-cols-12 lg:gap-4">
            <!-- Needs attention -->
            <div class="flex flex-col gap-3 lg:col-span-5" data-sim-panel="signals">
              <div
                class="sim-hero-signal rounded-xl border border-line bg-surface p-3.5 sm:p-4"
                data-sim-hero
              >
                <div class="flex items-center justify-between gap-2">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-ink-subtle">
                    Needs attention today
                  </p>
                  <span
                    class="sim-hero-badge rounded-md bg-canvas px-2 py-0.5 text-[10px] font-semibold text-ink-subtle"
                    data-sim-hero-badge
                  >
                    Watch
                  </span>
                </div>

                <div class="sim-hero-idle mt-3" data-sim-hero-idle>
                  <p class="text-sm text-ink-muted">Scanning for material changes…</p>
                </div>

                <div class="sim-hero-active hidden" data-sim-hero-active>
                  <p class="mt-1 text-[15px] font-semibold leading-snug tracking-tight text-ink sm:text-base">
                    West Region pull-through is slipping — forecast at risk
                  </p>
                  <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-[11px] text-ink-muted">
                    <span><span class="text-ink-subtle">Where:</span> West Region</span>
                    <span><span class="text-ink-subtle">At stake:</span> Revenue forecast &amp; margin</span>
                  </div>
                  <p class="mt-2 text-[11px] font-medium text-warning">Severity: High</p>
                </div>
              </div>

              <div class="sim-secondary space-y-2" data-sim-secondary>
                <p class="px-0.5 text-[11px] font-semibold uppercase tracking-[0.12em] text-ink-subtle">
                  Also watching
                </p>
                {
                  secondarySignals.map((signal) => (
                    <div class="rounded-lg border border-line bg-surface/90 px-3 py-2.5">
                      <p class="text-xs font-semibold text-ink">{signal.title}</p>
                      <p class="mt-1 text-[11px] text-ink-muted">
                        {signal.area} · {signal.stake}
                      </p>
                    </div>
                  ))
                }
              </div>
            </div>

            <!-- Cohi + Action -->
            <div class="flex flex-col gap-3 lg:col-span-7">
              <div
                class="sim-brief flex-1 rounded-xl border border-line bg-navy p-4 text-white sm:p-5"
                data-sim-brief
              >
                <div class="flex items-center gap-2">
                  <span class="sim-pulse-dot h-1.5 w-1.5 rounded-full bg-[#7dd3c7]"></span>
                  <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-white/60">
                    Cohi Executive Brief
                  </p>
                </div>
                <p class="sim-brief-idle mt-3 text-sm leading-relaxed text-white/70" data-sim-brief-idle>
                  Cohi is reviewing connected signals across production, pipeline, operations, and
                  profitability for material leadership issues.
                </p>
                <p
                  class="sim-brief-active mt-3 hidden text-sm leading-relaxed text-white/92 sm:text-[15px]"
                  data-sim-brief-active
                >
                  Fallout risk increased in the West Region, driven by longer processing cycle times,
                  delayed borrower conditions, and lower pull-through in two branches. This puts near-term
                  forecast and margin protection at risk.
                </p>
              </div>

              <div
                class="sim-action rounded-xl border border-line bg-surface p-4 sm:p-5"
                data-sim-action
              >
                <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-ink-subtle">
                  Recommended Action
                </p>
                <div class="sim-action-idle mt-3" data-sim-action-idle>
                  <p class="text-sm text-ink-muted">Waiting for prioritized executive focus…</p>
                </div>
                <div class="sim-action-active hidden" data-sim-action-active>
                  <p class="text-sm font-semibold leading-snug text-ink sm:text-[15px]">
                    Review West Region fallout drivers and processing delays.
                  </p>
                  <dl class="mt-3.5 grid gap-2 text-[12px] sm:grid-cols-2">
                    <div>
                      <dt class="font-medium text-ink-subtle">Owner</dt>
                      <dd class="mt-0.5 text-ink">Regional Operations Lead</dd>
                    </div>
                    <div>
                      <dt class="font-medium text-ink-subtle">Next step</dt>
                      <dd class="mt-0.5">
                        <span class="rounded-md bg-accent-soft px-2 py-0.5 text-[11px] font-semibold text-accent">
                          Open signal report
                        </span>
                      </dd>
                    </div>
                    <div class="sm:col-span-2">
                      <dt class="font-medium text-ink-subtle">Impact</dt>
                      <dd class="mt-0.5 text-ink-muted">
                        Revenue forecast, capacity planning, margin protection
                      </dd>
                    </div>
                  </dl>
                </div>
              </div>
            </div>
          </div>

          <!-- Ask Cohi: closing beat only -->
          <div class="sim-prompts mt-3 hidden sm:block" data-sim-prompts>
            <div class="rounded-xl border border-line bg-surface px-4 py-3">
              <div class="flex flex-wrap items-center gap-2">
                <p class="mr-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-ink-subtle">
                  Ask Cohi
                </p>
                {
                  prompts.map((prompt) => (
                    <span class="rounded-full border border-line bg-canvas px-2.5 py-1 text-[11px] font-medium text-ink-muted">
                      {prompt}
                    </span>
                  ))
                }
              </div>
            </div>
          </div>

          <!-- Scene 6: Today's Executive Focus -->
          <div
            class="sim-focus pointer-events-none absolute inset-3 z-40 flex items-center justify-center sm:inset-4"
            data-sim-focus
            aria-hidden="true"
          >
            <div
              class="w-full max-w-md rounded-2xl border border-line bg-surface/97 p-5 shadow-elevated backdrop-blur-sm sm:p-6"
            >
              <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-accent">
                Today’s Executive Focus
              </p>
              <p class="mt-2 text-sm leading-relaxed text-ink-muted">
                Leadership has a clear priority, an owner, and a next step — without another dashboard
                hunt.
              </p>
              <ul class="mt-4 space-y-2.5">
                {
                  focusItems.map((item) => (
                    <li class="flex items-center gap-2.5 text-sm text-ink">
                      <span
                        class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-accent-soft text-accent"
                        aria-hidden="true"
                      >
                        <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none">
                          <path
                            d="M2.5 6.2 L4.8 8.5 L9.5 3.5"
                            stroke="currentColor"
                            stroke-width="1.6"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          />
                        </svg>
                      </span>
                      {item}
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-4 flex items-center justify-center gap-2 sm:mt-5" aria-hidden="true">
        {
          [1, 2, 3, 4, 5, 6].map((n) => (
            <span
              class="sim-dot h-1.5 w-1.5 rounded-full bg-line-strong transition-all duration-300"
              data-sim-dot={n}
            />
          ))
        }
      </div>

      <p class="sr-only">
        This animation demonstrates Coheus connecting business signals, detecting material changes,
        elevating what needs attention, explaining why with Cohi, assigning an owned action, and
        summarizing today’s executive focus. The sequence loops automatically.
      </p>
    </div>
  </Container>
</section>

<style>
  .sim-sources {
    opacity: 0;
    transform: translateY(-4px);
    transition:
      opacity 0.45s ease,
      transform 0.45s ease;
  }

  .sim[data-scene='1'] .sim-sources {
    opacity: 1;
    transform: translateY(0);
  }

  .sim-source {
    opacity: 0;
    transform: translateY(-8px) scale(0.96);
  }

  .sim[data-scene='1'] .sim-source {
    animation: sim-source-in 1.9s ease-in-out both;
    animation-delay: calc(var(--i) * 0.1s);
  }

  @keyframes sim-source-in {
    0% {
      opacity: 0;
      transform: translateY(-10px) scale(0.96);
    }
    22% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    70% {
      opacity: 1;
      transform: translateY(12px) scale(1);
    }
    100% {
      opacity: 0;
      transform: translateY(32px) scale(0.94);
    }
  }

  .sim-kpi {
    transition:
      border-color 0.45s ease,
      box-shadow 0.45s ease;
  }

  .sim[data-scene='2'] .sim-kpi,
  .sim[data-scene='3'] .sim-kpi,
  .sim[data-scene='4'] .sim-kpi,
  .sim[data-scene='5'] .sim-kpi,
  .sim[data-scene='6'] .sim-kpi {
    border-color: color-mix(in oklab, var(--color-accent) 14%, var(--color-line));
  }

  .sim[data-scene='2'] .sim-kpi[data-sim-kpi='fallout'],
  .sim[data-scene='3'] .sim-kpi[data-sim-kpi='fallout'],
  .sim[data-scene='4'] .sim-kpi[data-sim-kpi='fallout'],
  .sim[data-scene='5'] .sim-kpi[data-sim-kpi='fallout'],
  .sim[data-scene='6'] .sim-kpi[data-sim-kpi='fallout'] {
    border-color: color-mix(in oklab, var(--color-warning) 30%, var(--color-line));
    box-shadow: var(--shadow-card);
  }

  .sim-kpi-fill {
    transition: width 0.7s ease;
  }

  /* Hero signal elevates from scene 3 */
  .sim-hero-signal {
    transition:
      border-color 0.45s ease,
      box-shadow 0.45s ease,
      transform 0.45s ease;
  }

  .sim[data-scene='3'] .sim-hero-signal,
  .sim[data-scene='4'] .sim-hero-signal,
  .sim[data-scene='5'] .sim-hero-signal,
  .sim[data-scene='6'] .sim-hero-signal {
    border-color: color-mix(in oklab, var(--color-warning) 30%, var(--color-line));
    box-shadow: var(--shadow-elevated);
    transform: translateY(-1px);
    background: #fbf7f0;
  }

  .sim-hero-active {
    display: none;
  }

  .sim[data-scene='3'] .sim-hero-idle,
  .sim[data-scene='4'] .sim-hero-idle,
  .sim[data-scene='5'] .sim-hero-idle,
  .sim[data-scene='6'] .sim-hero-idle {
    display: none;
  }

  .sim[data-scene='3'] .sim-hero-active,
  .sim[data-scene='4'] .sim-hero-active,
  .sim[data-scene='5'] .sim-hero-active,
  .sim[data-scene='6'] .sim-hero-active {
    display: block;
    animation: sim-fade-up 0.5s ease both;
  }

  .sim-secondary {
    opacity: 0.55;
    transition: opacity 0.45s ease;
  }

  .sim[data-scene='3'] .sim-secondary,
  .sim[data-scene='4'] .sim-secondary,
  .sim[data-scene='5'] .sim-secondary {
    opacity: 0.85;
  }

  /* Cohi brief centers narrative from scene 4 */
  .sim-brief {
    transition:
      box-shadow 0.45s ease,
      transform 0.45s ease,
      opacity 0.45s ease;
    opacity: 0.8;
  }

  .sim[data-scene='4'] .sim-brief,
  .sim[data-scene='5'] .sim-brief,
  .sim[data-scene='6'] .sim-brief {
    opacity: 1;
    box-shadow: var(--shadow-elevated);
    transform: translateY(-2px);
  }

  .sim-brief-active {
    display: none;
  }

  .sim[data-scene='4'] .sim-brief-idle,
  .sim[data-scene='5'] .sim-brief-idle,
  .sim[data-scene='6'] .sim-brief-idle {
    display: none;
  }

  .sim[data-scene='4'] .sim-brief-active,
  .sim[data-scene='5'] .sim-brief-active,
  .sim[data-scene='6'] .sim-brief-active {
    display: block;
    animation: sim-fade-up 0.55s ease both;
  }

  .sim-action {
    transition:
      border-color 0.45s ease,
      box-shadow 0.45s ease,
      transform 0.45s ease,
      opacity 0.45s ease;
    opacity: 0.65;
  }

  .sim[data-scene='5'] .sim-action,
  .sim[data-scene='6'] .sim-action {
    opacity: 1;
    border-color: color-mix(in oklab, var(--color-accent) 24%, var(--color-line));
    box-shadow: var(--shadow-elevated);
    transform: translateY(-2px);
  }

  .sim[data-scene='5'] .sim-action-idle,
  .sim[data-scene='6'] .sim-action-idle {
    display: none;
  }

  .sim[data-scene='5'] .sim-action-active,
  .sim[data-scene='6'] .sim-action-active {
    display: block;
    animation: sim-fade-up 0.55s ease both;
  }

  /* Ask Cohi appears late */
  .sim-prompts {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.45s ease,
      transform 0.45s ease;
    pointer-events: none;
  }

  .sim[data-scene='5'] .sim-prompts,
  .sim[data-scene='6'] .sim-prompts {
    opacity: 1;
    transform: translateY(0);
  }

  .sim-focus {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
    background: color-mix(in oklab, var(--color-canvas) 58%, transparent);
  }

  .sim[data-scene='6'] .sim-focus {
    opacity: 1;
    transform: translateY(0);
  }

  .sim-pulse-dot {
    opacity: 0.85;
  }

  .sim[data-scene='4'] .sim-pulse-dot,
  .sim[data-scene='5'] .sim-pulse-dot {
    animation: sim-pulse 1.4s ease-in-out infinite;
  }

  @keyframes sim-pulse {
    0%,
    100% {
      opacity: 0.35;
    }
    50% {
      opacity: 1;
    }
  }

  @keyframes sim-fade-up {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .sim-dot {
    opacity: 0.4;
  }

  .sim[data-scene='1'] .sim-dot[data-sim-dot='1'],
  .sim[data-scene='2'] .sim-dot[data-sim-dot='2'],
  .sim[data-scene='3'] .sim-dot[data-sim-dot='3'],
  .sim[data-scene='4'] .sim-dot[data-sim-dot='4'],
  .sim[data-scene='5'] .sim-dot[data-sim-dot='5'],
  .sim[data-scene='6'] .sim-dot[data-sim-dot='6'] {
    opacity: 1;
    background: var(--color-accent);
    transform: scale(1.25);
  }

  /* Mobile: Signal → Brief → Action */
  @media (max-width: 639px) {
    .sim[data-scene='1'] .sim-secondary,
    .sim[data-scene='2'] .sim-secondary {
      display: none;
    }

    .sim[data-scene='1'] .sim-action,
    .sim[data-scene='2'] .sim-action,
    .sim[data-scene='3'] .sim-action {
      display: none;
    }

    .sim[data-scene='1'] .sim-brief {
      display: none;
    }

    .sim[data-scene='1'] .sim-pulse-strip,
    .sim[data-scene='2'] .sim-pulse-strip {
      opacity: 0.9;
    }

    .sim-prompts {
      display: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sim-source,
    .sim-pulse-dot,
    .sim-brief-active,
    .sim-action-active,
    .sim-hero-active {
      animation: none !important;
    }

    .sim-sources,
    .sim-kpi,
    .sim-hero-signal,
    .sim-brief,
    .sim-action,
    .sim-focus,
    .sim-prompts,
    .sim-kpi-fill,
    .sim-secondary {
      transition: none !important;
    }

    .sim[data-scene='6'] .sim-focus {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  import { initProductSimulation } from '../scripts/product-simulation';
  initProductSimulation();
</script>
